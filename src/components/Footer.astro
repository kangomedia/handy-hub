<style>
  .footer {
    width: 100%;
    background-color: var(--color-bg-dark);
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--color-border-dark);
  }

  .footer__glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
    opacity: 0.4;
  }

  .footer__inner {
    position: relative;
    z-index: 1;
    padding-block: 5em 2em;
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    gap: 4em;
    padding-bottom: 3em;
    border-bottom: 1px solid var(--color-border-dark);
  }

  .footer__company {
    max-width: 22em;
    flex-shrink: 0;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.625em;
    margin-bottom: 1.25em;
  }

  .footer__logo-icon {
    width: 2.5em;
    height: 2.5em;
    object-fit: contain;
  }

  .footer__logo-text {
    font-family: var(--font-heading);
    font-size: 1.125em;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-white);
    line-height: 1.1;
  }

  .footer__logo-text--accent {
    color: var(--color-primary);
  }

  .footer__description {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1.5em;
  }

  .footer__nap {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
    margin-bottom: 1.5em;
  }

  .footer__nap-item {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.8125em;
    color: var(--color-text-white-muted);
    transition: color var(--transition-base);
  }

  .footer__nap-item svg {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    color: var(--color-primary);
  }

  a.footer__nap-item:hover {
    color: var(--color-primary);
  }

  .footer__social {
    display: flex;
    gap: 0.75em;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25em;
    height: 2.25em;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    color: var(--color-text-white-muted);
    transition: all var(--transition-base);
  }

  .footer__social-link svg {
    width: 1.125em;
    height: 1.125em;
  }

  .footer__social-link:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background-color: rgba(0, 200, 232, 0.08);
  }

  .footer__links {
    display: flex;
    gap: 4em;
  }

  .footer__link-heading {
    font-family: var(--font-heading);
    font-size: 0.875em;
    font-weight: 700;
    line-height: 1.5;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-white);
    margin-bottom: 1.25em;
  }

  .footer__link-list {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }

  .footer__link {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    transition: color var(--transition-base);
  }

  .footer__link:hover {
    color: var(--color-primary);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2em;
  }

  .footer__bottom-copy {
    font-family: var(--font-body);
    font-size: 0.8125em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-gray);
  }

  .footer__bottom-credit {
    font-family: var(--font-body);
    font-size: 0.8125em;
    font-weight: 400;
    color: var(--color-text-gray);
  }

  .footer__credit-link {
    color: var(--color-primary);
    transition: opacity var(--transition-base);
  }

  .footer__credit-link:hover {
    opacity: 0.7;
  }

  /* Tablet */
  @media (max-width: 991px) {
    .footer__top {
      flex-wrap: wrap;
      gap: 3em;
    }

    .footer__company {
      max-width: 100%;
      width: 100%;
    }

    .footer__links {
      width: 100%;
      gap: 3em;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .footer__inner {
      padding-block: 3em 1.5em;
    }

    .footer__top {
      flex-direction: column;
      gap: 2.5em;
    }

    .footer__links {
      flex-direction: column;
      gap: 2.5em;
    }

    .footer__bottom {
      flex-direction: column;
      gap: 0.75em;
      text-align: center;
    }
  }
</style>
