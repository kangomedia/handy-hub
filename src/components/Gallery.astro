---
export interface Props {
  title?: string;
  subtitle?: string;
  eyebrow?: string;
  images: Array<{
    src: string;
    alt: string;
    category?: string;
    location?: string;
  }>;
  variant?: 'default' | 'masonry' | 'filmstrip';
  columns?: 2 | 3 | 4;
  id?: string;
}

const {
  title = 'Our Recent Projects',
  subtitle = 'Browse a selection of our recent home improvement projects across Westminster and the Denver Metro area.',
  eyebrow = 'Portfolio',
  images = [],
  variant = 'default',
  columns = 4,
  id = 'gallery',
} = Astro.props;
---

<section class={`gallery gallery--${variant} gallery--cols-${columns}`} id={id}>
  <div class="gallery__inner container">
    <span class="section-label gallery__eyebrow">{eyebrow}</span>
    <h2 class="gallery__heading">{title}</h2>
    <p class="gallery__subtext">{subtitle}</p>
    <div class="gallery__grid">
      {images.map((img, i) => (
        <div class="gallery__item" data-index={i}>
          <img
            src={img.src}
            alt={img.alt}
            width="600"
            height="400"
            loading="lazy"
            class="gallery__img"
          />
          <div class="gallery__overlay">
            {img.category && <span class="gallery__category">{img.category}</span>}
            {img.location && <span class="gallery__location">{img.location}</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox Modal -->
<div class="gallery-lightbox" id={`${id}-lightbox`} role="dialog" aria-modal="true" aria-label="Image lightbox">
  <button class="gallery-lightbox__close" aria-label="Close lightbox">&times;</button>
  <button class="gallery-lightbox__prev" aria-label="Previous image">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <div class="gallery-lightbox__content">
    <img class="gallery-lightbox__img" src="" alt="" />
    <div class="gallery-lightbox__caption"></div>
  </div>
  <button class="gallery-lightbox__next" aria-label="Next image">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="gallery-lightbox__counter"></div>
</div>

<style>
  /* ==========================================================================
     Gallery Section
     ========================================================================== */
  .gallery {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 6.25em;
    border-top: 1px solid var(--color-border);
  }

  .gallery__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .gallery__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-top: 0.75em;
    margin-bottom: 0.5em;
  }

  .gallery__subtext {
    font-size: 1em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 3em;
    max-width: 36em;
  }

  /* Grid Layout */
  .gallery__grid {
    display: grid;
    gap: 0.75em;
    width: 100%;
  }

  .gallery--cols-2 .gallery__grid { grid-template-columns: repeat(2, 1fr); }
  .gallery--cols-3 .gallery__grid { grid-template-columns: repeat(3, 1fr); }
  .gallery--cols-4 .gallery__grid { grid-template-columns: repeat(4, 1fr); }

  /* Masonry-like variant */
  .gallery--masonry .gallery__grid {
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 200px;
  }

  .gallery--masonry .gallery__item:nth-child(3n + 1) {
    grid-row: span 2;
  }

  /* Gallery Item */
  .gallery__item {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 3 / 2;
    cursor: pointer;
  }

  .gallery--masonry .gallery__item {
    aspect-ratio: unset;
    height: 100%;
  }

  .gallery__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery__item:hover .gallery__img {
    transform: scale(1.08);
  }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 15, 20, 0.9) 0%, rgba(10, 15, 20, 0.1) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25em;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .gallery__item:hover .gallery__overlay {
    opacity: 1;
  }

  .gallery__category {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9375em;
    color: var(--color-text-white);
  }

  .gallery__location {
    font-size: 0.75em;
    color: var(--color-primary);
    margin-top: 0.25em;
  }

  /* ==========================================================================
     Lightbox
     ========================================================================== */
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(5, 8, 12, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }

  .gallery-lightbox.is-active {
    opacity: 1;
    visibility: visible;
  }

  .gallery-lightbox__close {
    position: absolute;
    top: 1.25em;
    right: 1.5em;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 2em;
    cursor: pointer;
    z-index: 10;
    width: 2em;
    height: 2em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.2s ease;
  }

  .gallery-lightbox__close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  .gallery-lightbox__content {
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .gallery-lightbox__img {
    max-width: 100%;
    max-height: 78vh;
    object-fit: contain;
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    transition: opacity 0.3s ease;
  }

  .gallery-lightbox__caption {
    margin-top: 1em;
    font-family: var(--font-heading);
    font-size: 0.9375em;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
  }

  .gallery-lightbox__prev,
  .gallery-lightbox__next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    width: 3em;
    height: 3em;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all 0.2s ease;
  }

  .gallery-lightbox__prev { left: 1.5em; }
  .gallery-lightbox__next { right: 1.5em; }

  .gallery-lightbox__prev:hover,
  .gallery-lightbox__next:hover {
    background: rgba(0, 200, 232, 0.15);
    border-color: rgba(0, 200, 232, 0.3);
    color: #fff;
  }

  .gallery-lightbox__counter {
    position: absolute;
    bottom: 1.5em;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.8125em;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-heading);
    letter-spacing: 0.1em;
  }

  /* ==========================================================================
     Responsive
     ========================================================================== */
  @media (max-width: 1024px) {
    .gallery--cols-4 .gallery__grid { grid-template-columns: repeat(3, 1fr); }
    .gallery--masonry .gallery__grid { grid-auto-rows: 175px; }
  }

  @media (max-width: 768px) {
    .gallery__heading { font-size: 2em; }
    .gallery--cols-4 .gallery__grid,
    .gallery--cols-3 .gallery__grid { grid-template-columns: repeat(2, 1fr); }
    .gallery--masonry .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }
    .gallery-lightbox__prev { left: 0.5em; }
    .gallery-lightbox__next { right: 0.5em; }
  }

  @media (max-width: 480px) {
    .gallery { padding-block: 4em; }
    .gallery--cols-4 .gallery__grid,
    .gallery--cols-3 .gallery__grid,
    .gallery--cols-2 .gallery__grid { grid-template-columns: 1fr; }
    .gallery--masonry .gallery__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }
    .gallery--masonry .gallery__item {
      aspect-ratio: 3 / 2;
    }
    .gallery--masonry .gallery__item:nth-child(3n + 1) {
      grid-row: span 1;
    }
  }
</style>

<script define:vars={{ id }}>
  document.addEventListener('DOMContentLoaded', () => {
    const gallery = document.getElementById(id);
    const lightbox = document.getElementById(`${id}-lightbox`);
    if (!gallery || !lightbox) return;

    const items = gallery.querySelectorAll('.gallery__item');
    const lbImg = lightbox.querySelector('.gallery-lightbox__img');
    const lbCaption = lightbox.querySelector('.gallery-lightbox__caption');
    const lbCounter = lightbox.querySelector('.gallery-lightbox__counter');
    const closeBtn = lightbox.querySelector('.gallery-lightbox__close');
    const prevBtn = lightbox.querySelector('.gallery-lightbox__prev');
    const nextBtn = lightbox.querySelector('.gallery-lightbox__next');

    let currentIndex = 0;
    const total = items.length;

    function openLightbox(idx) {
      currentIndex = idx;
      updateLightbox();
      lightbox.classList.add('is-active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('is-active');
      document.body.style.overflow = '';
    }

    function updateLightbox() {
      const item = items[currentIndex];
      const img = item.querySelector('.gallery__img');
      const cat = item.querySelector('.gallery__category');
      const loc = item.querySelector('.gallery__location');
      lbImg.src = img.src;
      lbImg.alt = img.alt;
      lbCaption.textContent = [cat?.textContent, loc?.textContent].filter(Boolean).join(' — ');
      lbCounter.textContent = `${currentIndex + 1} / ${total}`;
    }

    function nextImage() {
      currentIndex = (currentIndex + 1) % total;
      updateLightbox();
    }

    function prevImage() {
      currentIndex = (currentIndex - 1 + total) % total;
      updateLightbox();
    }

    items.forEach((item, i) => {
      item.addEventListener('click', () => openLightbox(i));
    });

    closeBtn.addEventListener('click', closeLightbox);
    prevBtn.addEventListener('click', prevImage);
    nextBtn.addEventListener('click', nextImage);

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('is-active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextImage();
      if (e.key === 'ArrowLeft') prevImage();
    });

    // Swipe support for mobile
    let touchStartX = 0;
    lightbox.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    lightbox.addEventListener('touchend', (e) => {
      const diff = e.changedTouches[0].screenX - touchStartX;
      if (Math.abs(diff) > 50) diff > 0 ? prevImage() : nextImage();
    }, { passive: true });
  });
</script>
