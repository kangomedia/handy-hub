---
interface Props {
  variant?: 'dark' | 'light';
}

const { variant = 'dark' } = Astro.props;
const isDark = variant === 'dark';
---

<nav class:list={['navbar', { 'navbar--light': !isDark }]} aria-label="Main navigation">
  <div class="navbar__inner container">
    <a href="/" class="navbar__logo" aria-label="Elite Property Innovations home">
      <img src="/assets/images/elite-logo.png" alt="" width="40" height="40" class="navbar__logo-icon" role="presentation" />
      <span class="navbar__logo-text">Elite Property<span class="navbar__logo-text--accent"> Innovations</span></span>
    </a>

    <button
      class="navbar__hamburger"
      type="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="navbar-menu"
    >
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
    </button>

    <div class="navbar__right">
      <ul id="navbar-menu" class="navbar__links" role="list">
        <li><a href="/" class="navbar__link">Home</a></li>
        <li><a href="/services" class="navbar__link">Services</a></li>
        <li><a href="/about" class="navbar__link">About</a></li>
        <li><a href="/contact" class="navbar__link">Contact</a></li>
      </ul>
      <a href="tel:7202991238" class="navbar__phone" aria-label="Call us at (720) 299-1238">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span>(720) 299-1238</span>
      </a>
      <a href="/contact" class="btn btn--accent navbar__cta">Get a Free Quote</a>
    </div>
  </div>
</nav>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const hamburger = document.querySelector('.navbar__hamburger');
    const menu = document.getElementById('navbar-menu');
    const navbar = document.querySelector('.navbar');
    if (!hamburger || !menu) return;

    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      menu.classList.toggle('navbar__links--open');
      hamburger.classList.toggle('navbar__hamburger--active');
    });

    // Sticky nav background on scroll
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (scrollY > 60) {
        navbar.classList.add('navbar--scrolled');
      } else {
        navbar.classList.remove('navbar--scrolled');
      }
      lastScroll = scrollY;
    }, { passive: true });
  });
</script>

<style>
  .navbar {
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition: background-color var(--transition-smooth), border-color var(--transition-smooth), backdrop-filter var(--transition-smooth);
  }

  .navbar--scrolled {
    background-color: rgba(10, 15, 20, 0.92);
    border-bottom-color: var(--color-border-dark);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .navbar--light {
    background-color: var(--color-bg-white);
    border-bottom-color: var(--color-border);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.25em;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.625em;
  }

  .navbar__logo-icon {
    width: 2.5em;
    height: 2.5em;
    object-fit: contain;
  }

  .navbar__logo-text {
    font-family: var(--font-heading);
    font-size: 1.125em;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-white);
    line-height: 1.1;
  }

  .navbar__logo-text--accent {
    color: var(--color-primary);
  }

  .navbar__right {
    display: flex;
    align-items: center;
    gap: 2em;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 2.5em;
  }

  .navbar__link {
    font-family: var(--font-body);
    font-size: 0.9375em;
    font-weight: 500;
    line-height: 1.5;
    color: var(--color-text-white-muted);
    transition: color var(--transition-base);
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -0.25em;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width var(--transition-base);
  }

  .navbar__link:hover {
    color: var(--color-text-white);
  }

  .navbar__link:hover::after {
    width: 100%;
  }

  .navbar--light .navbar__link {
    color: var(--color-text-secondary);
  }

  .navbar--light .navbar__link:hover {
    color: var(--color-text-primary);
  }

  .navbar__phone {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 600;
    color: var(--color-primary);
    transition: opacity var(--transition-base);
  }

  .navbar__phone svg {
    width: 1.125em;
    height: 1.125em;
    flex-shrink: 0;
  }

  .navbar__phone:hover {
    opacity: 0.8;
  }

  .navbar__cta {
    height: 2.75em;
    padding-inline: 1.5em;
    font-size: 0.875em;
  }

  /* Hamburger — hidden on desktop */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 0.3125em;
    width: 2.75em;
    height: 2.75em;
    padding: 0.5em;
    background: none;
    border: none;
    cursor: pointer;
  }

  .navbar__hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text-white);
    border-radius: 1px;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .navbar--light .navbar__hamburger-line {
    background-color: var(--color-text-primary);
  }

  .navbar__hamburger--active .navbar__hamburger-line:nth-child(1) {
    transform: translateY(0.4375em) rotate(45deg);
  }

  .navbar__hamburger--active .navbar__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .navbar__hamburger--active .navbar__hamburger-line:nth-child(3) {
    transform: translateY(-0.4375em) rotate(-45deg);
  }

  /* Tablet and below — hamburger menu */
  @media (max-width: 991px) {
    .navbar__hamburger {
      display: flex;
    }

    .navbar__right {
      flex-direction: column;
      gap: 0;
    }

    .navbar__links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      padding: 1em 0;
      background-color: rgba(10, 15, 20, 0.97);
      border-bottom: 1px solid var(--color-border-dark);
      backdrop-filter: blur(12px);
      z-index: 100;
    }

    .navbar--light .navbar__links {
      background-color: var(--color-bg-white);
      border-bottom-color: var(--color-border);
    }

    .navbar__links--open {
      display: flex;
    }

    .navbar__link {
      display: block;
      padding: 0.75em var(--container-padding);
      width: 100%;
    }

    .navbar__link::after {
      display: none;
    }

    .navbar__inner {
      position: relative;
    }

    .navbar__phone {
      display: none;
    }

    .navbar__cta {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .navbar__link {
      padding: 0.875em var(--container-padding);
    }
  }
</style>
