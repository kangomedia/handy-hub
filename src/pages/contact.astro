---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Gallery from '../components/Gallery.astro';

const contactGalleryImages = [
  { src: '/assets/images/portfolio/img_7092.jpeg', alt: 'Interior renovation by Elite Property Innovations', category: 'Interior Renovation', location: 'Westminster, CO' },
  { src: '/assets/images/portfolio/img_7135.jpeg', alt: 'Kitchen remodel project', category: 'Kitchen Remodel', location: 'Arvada, CO' },
  { src: '/assets/images/portfolio/img_8049.jpeg', alt: 'Bathroom transformation', category: 'Bathroom Remodel', location: 'Broomfield, CO' },
  { src: '/assets/images/portfolio/img_8540.jpeg', alt: 'Custom deck construction', category: 'Deck Build', location: 'Westminster, CO' },
  { src: '/assets/images/portfolio/img_8632.jpeg', alt: 'Full home remodel', category: 'Full Renovation', location: 'Denver, CO' },
  { src: '/assets/images/portfolio/img_9382.jpeg', alt: 'Professional painting work', category: 'Painting', location: 'Arvada, CO' },
];
---

<BaseLayout
  title="Contact Us | Free Estimates in Westminster & Denver — Elite Property Innovations"
  description="Contact Elite Property Innovations for a free home improvement estimate. Call (720) 299-1238 or fill out our form. Serving Westminster, Arvada, Broomfield, Thornton, Northglenn & Denver."
>
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- ========== CONTACT HERO ========== -->
    <section class="contact-hero">
      <div class="contact-hero__gradient" aria-hidden="true"></div>
      <div class="contact-hero__grid-overlay" aria-hidden="true"></div>
      <div class="contact-hero__inner container">
        <div class="contact-hero__header">
          <span class="section-label contact-hero__eyebrow">Contact Us</span>
          <h1 class="contact-hero__heading">Get Your Free Home Improvement&nbsp;Estimate</h1>
          <p class="contact-hero__subtext">
            Tell us about your project and we'll respond within 60 seconds — even after hours. Or call us directly at <a href="tel:7202991238" class="contact-hero__phone-link">(720) 299-1238</a>.
          </p>
        </div>
        <form class="contact-hero__form" action="#" method="post">
          <div class="contact-hero__form-row">
            <div class="contact-hero__form-group">
              <label for="full-name" class="contact-hero__label">Full Name</label>
              <input type="text" id="full-name" name="full-name" class="contact-hero__input" placeholder="Your full name" required />
            </div>
            <div class="contact-hero__form-group">
              <label for="phone" class="contact-hero__label">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="contact-hero__input" placeholder="(xxx) xxx-xxxx" required />
            </div>
          </div>
          <div class="contact-hero__form-row">
            <div class="contact-hero__form-group">
              <label for="email" class="contact-hero__label">Email Address</label>
              <input type="email" id="email" name="email" class="contact-hero__input" placeholder="your@email.com" />
            </div>
            <div class="contact-hero__form-group">
              <label for="service" class="contact-hero__label">Service Needed</label>
              <select id="service" name="service" class="contact-hero__input contact-hero__select" required>
                <option value="" disabled selected>Select a service</option>
                <option value="kitchen-remodeling">Kitchen Remodeling</option>
                <option value="bathroom-remodeling">Bathroom Remodeling</option>
                <option value="painting">Interior & Exterior Painting</option>
                <option value="handyman">Handyman Services</option>
                <option value="drywall">Drywall Services</option>
                <option value="carpentry">Carpentry</option>
                <option value="deck">Deck Construction & Repair</option>
                <option value="fence">Fence Installation & Repair</option>
                <option value="windows-doors">Window & Door Replacement</option>
                <option value="roofing">Roofing Services</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
          <div class="contact-hero__form-group">
            <label for="message" class="contact-hero__label">Project Details</label>
            <textarea id="message" name="message" class="contact-hero__input contact-hero__textarea" placeholder="Tell us about your project — scope, timeline, budget, or any questions you have..." rows="5"></textarea>
          </div>
          <button type="submit" class="btn btn--accent contact-hero__submit">Request Free Estimate</button>
        </form>
      </div>
    </section>

    <!-- ========== CONTACT IMAGE FEATURE ========== -->
    <section class="contact-feature">
      <div class="contact-feature__inner container">
        <div class="contact-feature__image-wrap">
          <img src="/assets/images/contact-image.jpg" alt="Elite Property Innovations contractor consultation with Westminster homeowner" width="600" height="400" loading="lazy" class="contact-feature__img" />
        </div>
        <div class="contact-feature__content">
          <h2 class="contact-feature__heading">What to Expect</h2>
          <div class="contact-feature__steps">
            <div class="contact-feature__step">
              <span class="contact-feature__step-num">1</span>
              <div>
                <h3 class="contact-feature__step-title">Submit Your Request</h3>
                <p class="contact-feature__step-text">Fill out the form above or call us directly. We respond within 60 seconds.</p>
              </div>
            </div>
            <div class="contact-feature__step">
              <span class="contact-feature__step-num">2</span>
              <div>
                <h3 class="contact-feature__step-title">Free On-Site Estimate</h3>
                <p class="contact-feature__step-text">We'll visit your home, assess the project, and provide a detailed written estimate — no obligation.</p>
              </div>
            </div>
            <div class="contact-feature__step">
              <span class="contact-feature__step-num">3</span>
              <div>
                <h3 class="contact-feature__step-title">Project Begins</h3>
                <p class="contact-feature__step-text">Once approved, we schedule your project and keep you updated every step of the way.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CONTACT INFO SECTION ========== -->
    <section class="contact-info">
      <div class="contact-info__inner container">
        <div class="contact-info__cards">
          <!-- Phone -->
          <a href="tel:7202991238" class="contact-info__card">
            <div class="contact-info__card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h3 class="contact-info__card-title">Call Us</h3>
            <p class="contact-info__card-text">(720) 299-1238</p>
            <span class="contact-info__card-note">Mon – Sat, 7am – 7pm</span>
          </a>
          <!-- Email -->
          <a href="mailto:jacob@epiinnovations.com" class="contact-info__card">
            <div class="contact-info__card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="contact-info__card-title">Email Us</h3>
            <p class="contact-info__card-text">jacob@epiinnovations.com</p>
            <span class="contact-info__card-note">We respond within 24 hours</span>
          </a>
          <!-- Location -->
          <a href="https://www.google.com/maps/search/Elite+Property+Innovations+Westminster+CO" target="_blank" rel="noopener noreferrer" class="contact-info__card">
            <div class="contact-info__card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="contact-info__card-title">Service Area</h3>
            <p class="contact-info__card-text">Westminster, CO</p>
            <span class="contact-info__card-note">Serving the Denver Metro</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ========== SERVICE AREAS ========== -->
    <section class="service-areas">
      <div class="service-areas__inner container">
        <span class="section-label">Service Areas</span>
        <h2 class="service-areas__heading">Proudly Serving the Denver Metro</h2>
        <p class="service-areas__subtext">We provide home improvement services throughout the northern Denver metro area, including:</p>
        <div class="service-areas__grid">
          <div class="service-areas__area">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Westminster</span>
          </div>
          <div class="service-areas__area">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Arvada</span>
          </div>
          <div class="service-areas__area">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Broomfield</span>
          </div>
          <div class="service-areas__area">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Thornton</span>
          </div>
          <div class="service-areas__area">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Northglenn</span>
          </div>
          <div class="service-areas__area">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Denver</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Portfolio Gallery -->
    <Gallery
      eyebrow="See Our Work"
      title="Projects That Speak for Themselves"
      subtitle="Every photo shows real work completed by our team — no stock imagery, just honest craftsmanship."
      images={contactGalleryImages}
      variant="default"
      columns={3}
      id="contact-gallery"
    />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ========== CONTACT HERO ========== */
  .contact-hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    background-image: url('/assets/images/contact-image.jpg');
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    padding: 10em 0 6em;
  }

  .contact-hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10, 15, 20, 0.85) 0%, rgba(10, 15, 20, 0.92) 100%),
                radial-gradient(ellipse at 30% 20%, rgba(0, 200, 232, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(168, 224, 0, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .contact-hero__grid-overlay {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.02) 0px,
      rgba(255, 255, 255, 0.02) 1px,
      transparent 1px,
      transparent 60px
    );
    pointer-events: none;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
  }

  .contact-hero__header {
    text-align: center;
    margin-bottom: 3em;
  }

  .contact-hero__eyebrow {
    display: block;
    margin-bottom: 1.5em;
  }

  .contact-hero__heading {
    font-family: var(--font-heading);
    font-size: 3.5em;
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .contact-hero__subtext {
    font-size: 1.0625em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 36em;
    margin-inline: auto;
  }

  .contact-hero__phone-link {
    color: var(--color-primary);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .contact-hero__phone-link:hover {
    color: var(--color-accent);
  }

  .contact-hero__form {
    max-width: 46em;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 1.25em;
  }

  .contact-hero__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25em;
  }

  .contact-hero__form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .contact-hero__label {
    font-size: 0.875em;
    font-weight: 500;
    color: var(--color-text-white);
  }

  .contact-hero__input {
    width: 100%;
    padding: 1em 1.25em;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1em;
    line-height: 1.5;
    color: var(--color-text-white);
    transition: border-color var(--transition-fast);
  }

  .contact-hero__input:focus {
    border-color: var(--color-primary);
    outline: none;
    box-shadow: var(--shadow-glow-cyan);
  }

  .contact-hero__input::placeholder {
    color: var(--color-text-gray);
  }

  .contact-hero__select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%2300C8E8' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1.25em center;
    padding-right: 3em;
    cursor: pointer;
  }

  .contact-hero__textarea {
    resize: vertical;
    min-height: 7em;
  }

  .contact-hero__submit {
    align-self: flex-start;
    min-width: 14em;
  }

  /* ========== CONTACT FEATURE ========== */
  .contact-feature {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 6.25em;
    border-top: 1px solid var(--color-border);
  }

  .contact-feature__inner {
    display: flex;
    align-items: center;
    gap: 4em;
  }

  .contact-feature__image-wrap {
    flex: 1;
    min-width: 0;
  }

  .contact-feature__img {
    width: 100%;
    height: 24em;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    display: block;
  }

  .contact-feature__content {
    flex: 1;
    min-width: 0;
  }

  .contact-feature__heading {
    font-family: var(--font-heading);
    font-size: 2.25em;
    font-weight: 800;
    color: var(--color-text-white);
    margin-bottom: 1.5em;
  }

  .contact-feature__steps {
    display: flex;
    flex-direction: column;
    gap: 1.75em;
  }

  .contact-feature__step {
    display: flex;
    align-items: flex-start;
    gap: 1em;
  }

  .contact-feature__step-num {
    width: 2.5em;
    height: 2.5em;
    border-radius: 50%;
    background: rgba(0, 200, 232, 0.1);
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-feature__step-title {
    font-family: var(--font-heading);
    font-size: 1.0625em;
    font-weight: 700;
    color: var(--color-text-white);
    margin-bottom: 0.25em;
  }

  .contact-feature__step-text {
    font-size: 0.875em;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ========== CONTACT INFO ========== */
  .contact-info {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 6.25em;
  }

  .contact-info__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25em;
  }

  .contact-info__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5em 2em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    color: inherit;
  }

  .contact-info__card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .contact-info__card-icon {
    width: 3.5em;
    height: 3.5em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 200, 232, 0.08);
    border-radius: var(--radius-md);
    margin-bottom: 1.25em;
    color: var(--color-primary);
  }

  .contact-info__card-title {
    font-family: var(--font-heading);
    font-size: 1.125em;
    font-weight: 700;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .contact-info__card-text {
    font-size: 1em;
    font-weight: 500;
    color: var(--color-primary);
    margin-bottom: 0.25em;
  }

  .contact-info__card-note {
    font-size: 0.8125em;
    color: var(--color-text-secondary);
  }

  /* ========== SERVICE AREAS ========== */
  .service-areas {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 6.25em;
    border-top: 1px solid var(--color-border);
  }

  .service-areas__inner {
    text-align: center;
  }

  .service-areas__heading {
    font-family: var(--font-heading);
    font-size: 2.5em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-top: 0.75em;
    margin-bottom: 0.5em;
  }

  .service-areas__subtext {
    font-size: 1em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 2.5em;
  }

  .service-areas__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25em;
    max-width: 56em;
    margin-inline: auto;
  }

  .service-areas__area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5em;
    padding: 1.5em 1em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-primary);
    transition: all var(--transition-base);
  }

  .service-areas__area:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
  }

  .service-areas__area span {
    font-family: var(--font-heading);
    font-size: 0.875em;
    font-weight: 600;
    color: var(--color-text-white);
  }

  /* ========== RESPONSIVE ========== */

  /* Tablet */
  @media (max-width: 991px) {
    .contact-hero__heading {
      font-size: 2.75em;
    }

    .contact-hero__form-row {
      grid-template-columns: 1fr;
    }

    .contact-info__cards {
      grid-template-columns: 1fr;
    }

    .service-areas__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .contact-feature__inner {
      flex-direction: column;
      gap: 2em;
    }

    .contact-feature__img {
      height: 18em;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .contact-hero {
      padding: 8em 0 4em;
    }

    .contact-hero__heading {
      font-size: 2.25em;
    }

    .contact-hero__submit {
      width: 100%;
    }

    .service-areas__heading {
      font-size: 2em;
    }

    .service-areas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Mobile portrait */
  @media (max-width: 479px) {
    .contact-hero__heading {
      font-size: 1.875em;
    }

    .service-areas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
