---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact Us | HandyHub" description="Get in touch with HandyHub today for a free estimate. Our team is ready to help with all your home improvement needs.">
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- ========== CONTACT HERO ========== -->
    <section class="contact-hero">
      <div class="contact-hero__lines" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <div class="contact-hero__inner container">
        <div class="contact-hero__header">
          <span class="section-label contact-hero__eyebrow">HANDYHUB</span>
          <h1 class="contact-hero__heading">Get in touch with us today</h1>
          <p class="contact-hero__subtext">
            Have a question or need a quote? Fill out the form below and our team will get back to you within 24 hours.
          </p>
        </div>
        <form class="contact-hero__form" action="#" method="post">
          <div class="contact-hero__form-row">
            <div class="contact-hero__form-group">
              <label for="full-name" class="contact-hero__label">Full Name</label>
              <input
                type="text"
                id="full-name"
                name="full-name"
                class="contact-hero__input"
                placeholder="Enter your full name"
                required
              />
            </div>
            <div class="contact-hero__form-group">
              <label for="phone" class="contact-hero__label">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="contact-hero__input"
                placeholder="Enter your phone number"
                required
              />
            </div>
          </div>
          <div class="contact-hero__form-group">
            <label for="service" class="contact-hero__label">Select Services</label>
            <select id="service" name="service" class="contact-hero__input contact-hero__select" required>
              <option value="" disabled selected>Select a service</option>
              <option value="plumbing">Plumbing</option>
              <option value="electrical">Electrical</option>
              <option value="painting">Painting</option>
              <option value="carpentry">Carpentry</option>
              <option value="general-repair">General Repair</option>
              <option value="renovation">Renovation</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="contact-hero__form-group">
            <label for="message" class="contact-hero__label">Your message</label>
            <textarea
              id="message"
              name="message"
              class="contact-hero__input contact-hero__textarea"
              placeholder="Tell us about your project..."
              rows="5"
            ></textarea>
          </div>
          <button type="submit" class="btn btn--light contact-hero__submit">Submit</button>
        </form>
      </div>
    </section>

    <!-- ========== MAPS SECTION ========== -->
    <section class="maps-section">
      <div class="maps-section__inner container">
        <div class="maps-section__header">
          <span class="section-label">HANDYHUB</span>
          <h2 class="maps-section__heading">Find our office</h2>
        </div>
        <div class="maps-section__map" role="img" aria-label="Map showing HandyHub office locations">
          <span class="maps-section__map-placeholder">Map</span>
        </div>
        <div class="maps-section__offices">
          <div class="maps-section__office">
            <div class="maps-section__office-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <h3 class="maps-section__office-title">Office</h3>
              <p class="maps-section__office-address">123 Street, New York, NY 10001</p>
              <a href="#" class="maps-section__office-direction">Direction <span aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
          <div class="maps-section__office">
            <div class="maps-section__office-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <h3 class="maps-section__office-title">Office</h3>
              <p class="maps-section__office-address">123 Street, New York, NY 10001</p>
              <a href="#" class="maps-section__office-direction">Direction <span aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
          <div class="maps-section__office">
            <div class="maps-section__office-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <h3 class="maps-section__office-title">Office</h3>
              <p class="maps-section__office-address">123 Street, New York, NY 10001</p>
              <a href="#" class="maps-section__office-direction">Direction <span aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
          <div class="maps-section__office">
            <div class="maps-section__office-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
            </div>
            <div>
              <h3 class="maps-section__office-title">Office</h3>
              <p class="maps-section__office-address">123 Street, New York, NY 10001</p>
              <a href="#" class="maps-section__office-direction">Direction <span aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ========== CONTACT HERO ========== */
  .contact-hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    position: relative;
    overflow: hidden;
    padding-block: 7.5em;
  }

  .contact-hero__lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    justify-content: space-evenly;
    max-width: var(--size-container);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .contact-hero__lines span {
    width: 1px;
    height: 100%;
    background-color: var(--color-border-dark);
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
    padding-inline: var(--container-padding);
  }

  .contact-hero__header {
    text-align: center;
    margin-bottom: 3.75em;
  }

  .contact-hero__eyebrow {
    display: block;
    color: var(--color-text-white-muted);
    margin-bottom: 1.5em;
  }

  .contact-hero__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.92px;
    color: var(--color-text-white);
    margin-bottom: 0.267em;
  }

  .contact-hero__subtext {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-white-muted);
    max-width: 34.5em;
    margin-inline: auto;
  }

  .contact-hero__form {
    max-width: 46.5em;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .contact-hero__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5em;
  }

  .contact-hero__form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .contact-hero__label {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 400;
    line-height: 1.429;
    color: var(--color-text-white-muted);
  }

  .contact-hero__input {
    width: 100%;
    padding: 1.25em;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 1em;
    line-height: 1.5;
    color: var(--color-text-white);
  }

  .contact-hero__input::placeholder {
    color: var(--color-text-gray);
  }

  .contact-hero__select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%23969ea3' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 1.25em center;
    padding-right: 3em;
    cursor: pointer;
  }

  .contact-hero__textarea {
    resize: vertical;
    min-height: 8em;
  }

  .contact-hero__submit {
    align-self: flex-start;
    min-width: 10em;
  }

  /* ========== MAPS SECTION ========== */
  .maps-section {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 7.5em;
  }

  .maps-section__inner {
    padding-inline: var(--container-padding);
  }

  .maps-section__header {
    text-align: center;
    margin-bottom: 3.75em;
  }

  .maps-section__header .section-label {
    display: block;
    color: var(--color-text-white-muted);
    margin-bottom: 1em;
  }

  .maps-section__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.92px;
    color: var(--color-text-white);
  }

  .maps-section__map {
    width: 100%;
    height: 39.6875em;
    background-color: #2a3a47;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 3.75em;
  }

  .maps-section__map-placeholder {
    font-family: var(--font-heading);
    font-size: 2em;
    font-weight: 400;
    color: var(--color-text-white-muted);
  }

  .maps-section__offices {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25em;
  }

  .maps-section__office {
    display: flex;
    gap: 1em;
    align-items: flex-start;
    padding: 2em;
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-lg);
  }

  .maps-section__office-icon {
    width: 2.5em;
    height: 2.5em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-text-white);
  }

  .maps-section__office-title {
    font-family: var(--font-heading);
    font-size: 1.25em;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-white);
    margin-bottom: 0.25em;
  }

  .maps-section__office-address {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-white-muted);
    margin-bottom: 0.75em;
  }

  .maps-section__office-direction {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 500;
    line-height: 1.429;
    color: var(--color-text-white);
    transition: opacity var(--transition-base);
  }

  .maps-section__office-direction:hover {
    opacity: 0.7;
  }

  /* ========== RESPONSIVE ========== */

  /* Tablet */
  @media (max-width: 991px) {
    .contact-hero__form-row {
      grid-template-columns: 1fr;
    }

    .maps-section__offices {
      grid-template-columns: 1fr;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .contact-hero__heading,
    .maps-section__heading {
      font-size: 2.5em;
    }

    .maps-section__map {
      height: 20em;
    }

    .contact-hero__submit {
      width: 100%;
    }
  }

  /* Mobile portrait */
  @media (max-width: 479px) {
    .contact-hero__heading,
    .maps-section__heading {
      font-size: 2em;
    }

    .maps-section__map {
      height: 15em;
    }
  }
</style>
