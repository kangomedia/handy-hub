---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Gallery from '../../components/Gallery.astro';

const areaGalleryImages = [
  { src: '/assets/images/portfolio/img_7092.jpeg', alt: 'Home renovation project in Denver, CO', category: 'Interior Renovation', location: 'Denver, CO' },
  { src: '/assets/images/portfolio/img_8049.jpeg', alt: 'Bathroom remodel in Denver, CO', category: 'Bathroom Remodel', location: 'Denver, CO' },
  { src: '/assets/images/portfolio/img_7135.jpeg', alt: 'Kitchen transformation in Denver, CO', category: 'Kitchen Remodel', location: 'Denver, CO' },
  { src: '/assets/images/portfolio/img_8540.jpeg', alt: 'Deck construction project near Denver', category: 'Deck Build', location: 'Denver, CO' },
  { src: '/assets/images/portfolio/img_8632.jpeg', alt: 'Full home improvement in Denver area', category: 'Full Renovation', location: 'Denver, CO' },
  { src: '/assets/images/portfolio/img_9382.jpeg', alt: 'Professional painting in Denver, CO', category: 'Painting', location: 'Denver, CO' },
];
---

<BaseLayout
  title="Home Remodeling in Denver, CO — Elite Property Innovations"
  description="Denver's trusted home remodeling and property improvement contractor. Kitchen & bathroom remodels, painting, handyman services, decks & more. 25+ years experience. Free estimates — (720) 299-1238."
>
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- Hero -->
    <section class="sa-page-hero">
      <div class="sa-page-hero__gradient" aria-hidden="true"></div>
      <div class="sa-page-hero__grid-overlay" aria-hidden="true"></div>
      <div class="sa-page-hero__content container">
        <div class="sa-page-hero__text">
          <span class="section-label sa-page-hero__eyebrow">Denver, CO</span>
          <h1 class="sa-page-hero__heading">Home Remodeling &amp; Repair in Denver, CO</h1>
          <p class="sa-page-hero__subtext">Denver homeowners choose Elite Property Innovations for expert craftsmanship and reliable home improvement services. From kitchen remodels to handyman repairs, we treat every project like it's our own home.</p>
          <div class="sa-page-hero__ctas">
            <a href="/contact" class="btn btn--accent">Get a Free Estimate in Denver</a>
            <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
          </div>
        </div>
        <div class="sa-page-hero__stats">
          <div class="sa-page-hero__stat">
            <span class="sa-page-hero__stat-number">25+</span>
            <span class="sa-page-hero__stat-label">YEARS EXPERIENCE</span>
          </div>
          <div class="sa-page-hero__stat">
            <span class="sa-page-hero__stat-number">1,000+</span>
            <span class="sa-page-hero__stat-label">PROJECTS COMPLETED</span>
          </div>
          <div class="sa-page-hero__stat">
            <span class="sa-page-hero__stat-number">5.0★</span>
            <span class="sa-page-hero__stat-label">GOOGLE RATING</span>
          </div>
          <div class="sa-page-hero__stat">
            <span class="sa-page-hero__stat-number">100%</span>
            <span class="sa-page-hero__stat-label">SATISFACTION GUARANTEE</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="sa-page-benefits">
      <div class="sa-page-benefits__inner container">
        <span class="section-label">Why Denver Homeowners Choose Us</span>
        <h2 class="sa-page-benefits__heading">Your Denver Home Improvement Partner</h2>
        <p class="sa-page-benefits__subtext">We've built our reputation in Denver by delivering quality work, honest pricing, and reliable service on every single project.</p>
        <div class="sa-page-benefits__grid">
          <div class="sa-page-benefit-card">
            <div class="sa-page-benefit-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="sa-page-benefit-card__title">Local Expertise</h3>
            <p class="sa-page-benefit-card__desc">Serving the greater Denver metro area, we understand local building codes, HOA requirements, and the unique challenges Colorado homes face.</p>
          </div>
          <div class="sa-page-benefit-card">
            <div class="sa-page-benefit-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="sa-page-benefit-card__title">Licensed & Insured</h3>
            <p class="sa-page-benefit-card__desc">Fully licensed and insured for your protection. We carry comprehensive liability and workers' comp coverage on every job.</p>
          </div>
          <div class="sa-page-benefit-card">
            <div class="sa-page-benefit-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="sa-page-benefit-card__title">Fast Response Times</h3>
            <p class="sa-page-benefit-card__desc">Being local means we can respond quickly. Most estimates are scheduled within 48 hours, and we start work on your timeline.</p>
          </div>
          <div class="sa-page-benefit-card">
            <div class="sa-page-benefit-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 class="sa-page-benefit-card__title">Warranty on All Work</h3>
            <p class="sa-page-benefit-card__desc">Every project comes with our craftsmanship warranty. If something isn't right, we'll make it right — no questions asked.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Image -->
    <section class="sa-page-feature-image">
      <div class="sa-page-feature-image__inner container">
        <img src="/assets/images/about-story.jpg" alt="Professional home remodeling work in Denver, CO — Elite Property Innovations" width="1200" height="500" loading="lazy" class="sa-page-feature-image__img" />
      </div>
    </section>

    <!-- Services Accordion -->
    <section class="sa-page-included">
      <div class="sa-page-included__inner container">
        <div class="sa-page-included__left">
          <span class="section-label">Services in Denver</span>
          <h2 class="sa-page-included__heading">Complete Home Improvement Services</h2>
          <p class="sa-page-included__desc">From minor handyman repairs to complete home transformations, we offer a full range of professional services for Denver homeowners.</p>
          <div class="sa-page-included__cta">
            <a href="/contact" class="btn btn--accent">Get Your Denver Quote</a>
          </div>
        </div>
        <div class="sa-page-included__right">
          <div class="sa-page-accordion" data-accordion>
            <div class="sa-page-accordion__item sa-page-accordion__item--active" data-accordion-item>
              <button class="sa-page-accordion__header" type="button" aria-expanded="true">
                <div class="sa-page-accordion__header-left">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sa-page-accordion__icon-svg"><path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/><path d="M3 9V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4"/></svg>
                  <span class="sa-page-accordion__title">KITCHEN REMODELING</span>
                </div>
                <span class="sa-page-accordion__toggle" aria-hidden="true"><svg width="14" height="2" viewBox="0 0 14 2" fill="none"><rect width="14" height="2" fill="currentColor"/></svg></span>
              </button>
              <div class="sa-page-accordion__body">
                <p class="sa-page-accordion__text">Custom kitchen remodels designed for Denver homes. Cabinet refacing, countertop installation, backsplash, layout redesigns, and complete gut renovations. <a href="/services/kitchen-remodeling">Learn more →</a></p>
              </div>
            </div>
            <div class="sa-page-accordion__item" data-accordion-item>
              <button class="sa-page-accordion__header" type="button" aria-expanded="false">
                <div class="sa-page-accordion__header-left">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sa-page-accordion__icon-svg"><path d="M4 12h16a1 1 0 0 1 1 1v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-3a1 1 0 0 1 1-1z"/><path d="M6 12V5a2 2 0 0 1 2-2h1"/></svg>
                  <span class="sa-page-accordion__title">BATHROOM REMODELING</span>
                </div>
                <span class="sa-page-accordion__toggle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg></span>
              </button>
              <div class="sa-page-accordion__body" hidden><p class="sa-page-accordion__text">Transform your bathroom with custom tile, new vanities, walk-in showers, and tub-to-shower conversions. <a href="/services/bathroom-remodeling">Learn more →</a></p></div>
            </div>
            <div class="sa-page-accordion__item" data-accordion-item>
              <button class="sa-page-accordion__header" type="button" aria-expanded="false">
                <div class="sa-page-accordion__header-left">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sa-page-accordion__icon-svg"><path d="M19 3H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/><path d="M12 11v6"/><path d="M8 17h8"/></svg>
                  <span class="sa-page-accordion__title">INTERIOR & EXTERIOR PAINTING</span>
                </div>
                <span class="sa-page-accordion__toggle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg></span>
              </button>
              <div class="sa-page-accordion__body" hidden><p class="sa-page-accordion__text">Professional painting services with premium paints designed for Colorado's climate. Interior rooms, exterior facades, trim, and accent walls. <a href="/services/painting">Learn more →</a></p></div>
            </div>
            <div class="sa-page-accordion__item" data-accordion-item>
              <button class="sa-page-accordion__header" type="button" aria-expanded="false">
                <div class="sa-page-accordion__header-left">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sa-page-accordion__icon-svg"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                  <span class="sa-page-accordion__title">HANDYMAN SERVICES</span>
                </div>
                <span class="sa-page-accordion__toggle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg></span>
              </button>
              <div class="sa-page-accordion__body" hidden><p class="sa-page-accordion__text">No job too small. From fixing leaky faucets to installing ceiling fans, our handyman team handles your entire honey-do list. <a href="/services/handyman">Learn more →</a></p></div>
            </div>
            <div class="sa-page-accordion__item" data-accordion-item>
              <button class="sa-page-accordion__header" type="button" aria-expanded="false">
                <div class="sa-page-accordion__header-left">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sa-page-accordion__icon-svg"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
                  <span class="sa-page-accordion__title">DRYWALL, CARPENTRY & MORE</span>
                </div>
                <span class="sa-page-accordion__toggle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg></span>
              </button>
              <div class="sa-page-accordion__body" hidden><p class="sa-page-accordion__text">Drywall repair & installation, custom carpentry, deck construction, fencing, window & door replacement, and roofing services. <a href="/services">View all services →</a></p></div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- Portfolio Gallery -->
    <Gallery
      eyebrow="Our Work in Denver"
      title="Recent Denver Projects"
      subtitle="Browse recent home improvement projects we've completed in Denver and the surrounding areas."
      images={areaGalleryImages}
      variant="default"
      columns={3}
      id="denver-gallery"
    />
    <!-- CTA Banner -->
    <section class="sa-page-cta-banner">
      <div class="sa-page-cta-banner__inner container">
        <h2 class="sa-page-cta-banner__heading">Ready to Improve Your Denver Home?</h2>
        <p class="sa-page-cta-banner__text">Get a detailed, no-obligation estimate for your next home improvement project. We'll walk you through materials, timelines, and pricing — no pressure.</p>
        <div class="sa-page-cta-banner__actions">
          <a href="/contact" class="btn btn--accent">Get Your Free Denver Estimate</a>
          <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const accordion = document.querySelector('[data-accordion]');
    if (!accordion) return;
    const items = accordion.querySelectorAll('[data-accordion-item]');
    items.forEach((item) => {
      const header = item.querySelector('.sa-page-accordion__header');
      const body = item.querySelector('.sa-page-accordion__body');
      const toggle = item.querySelector('.sa-page-accordion__toggle');
      header.addEventListener('click', () => {
        const isOpen = item.classList.contains('sa-page-accordion__item--active');
        items.forEach((otherItem) => {
          otherItem.classList.remove('sa-page-accordion__item--active');
          const otherBody = otherItem.querySelector('.sa-page-accordion__body');
          const otherHeader = otherItem.querySelector('.sa-page-accordion__header');
          const otherToggle = otherItem.querySelector('.sa-page-accordion__toggle');
          otherBody.hidden = true;
          otherHeader.setAttribute('aria-expanded', 'false');
          otherToggle.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg>';
        });
        if (!isOpen) {
          item.classList.add('sa-page-accordion__item--active');
          body.hidden = false;
          header.setAttribute('aria-expanded', 'true');
          toggle.innerHTML = '<svg width="14" height="2" viewBox="0 0 14 2" fill="none"><rect width="14" height="2" fill="currentColor"/></svg>';
        }
      });
    });
  });
</script>

<style>
  /* Hero */
  .sa-page-hero { width: 100%; background-color: var(--color-bg-dark); background-image: url('/assets/images/hero-about.jpg'); background-size: cover; background-position: center; position: relative; overflow: hidden; padding: 10em 0 6em; }
  .sa-page-hero__gradient { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,15,20,0.8) 0%, rgba(10,15,20,0.92) 100%), radial-gradient(ellipse at 30% 20%, rgba(0,200,232,0.08) 0%, transparent 60%), radial-gradient(ellipse at 70% 80%, rgba(168,224,0,0.05) 0%, transparent 50%); pointer-events: none; }
  .sa-page-hero__grid-overlay { position: absolute; inset: 0; background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px, transparent 1px, transparent 60px); pointer-events: none; }
  .sa-page-hero__content { position: relative; z-index: 2; }
  .sa-page-hero__text { display: flex; flex-direction: column; align-items: flex-start; max-width: 36em; }
  .sa-page-hero__eyebrow { margin-bottom: 1.5em; }
  .sa-page-hero__heading { font-family: var(--font-heading); font-size: 3.5em; font-weight: 800; line-height: 1.1; color: var(--color-text-white); margin-bottom: 0.4em; }
  .sa-page-hero__subtext { font-size: 1.0625em; line-height: 1.6; color: var(--color-text-secondary); margin-bottom: 2em; }
  .sa-page-hero__ctas { display: flex; gap: 1em; flex-wrap: wrap; }
  .sa-page-hero__stats { display: flex; gap: 3em; margin-top: 3em; padding-top: 2em; border-top: 1px solid var(--color-border); }
  .sa-page-hero__stat { display: flex; flex-direction: column; gap: 0.25em; }
  .sa-page-hero__stat-number { font-family: var(--font-heading); font-size: 2em; font-weight: 800; line-height: 1.2; color: var(--color-text-white); }
  .sa-page-hero__stat-label { font-size: 0.6875em; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--color-text-secondary); }

  /* Benefits */
  .sa-page-benefits { width: 100%; background-color: var(--color-bg-white); padding-block: 6.25em; }
  .sa-page-benefits__inner { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .sa-page-benefits__heading { font-family: var(--font-heading); font-size: 2.75em; font-weight: 800; line-height: 1.15; color: var(--color-text-white); margin-top: 0.75em; margin-bottom: 0.5em; }
  .sa-page-benefits__subtext { font-size: 1em; line-height: 1.6; color: var(--color-text-secondary); max-width: 40em; margin-bottom: 3em; }
  .sa-page-benefits__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25em; width: 100%; max-width: 60em; }
  .sa-page-benefit-card { display: flex; flex-direction: column; align-items: flex-start; text-align: left; padding: 2em; background-color: var(--color-bg-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); transition: all var(--transition-base); }
  .sa-page-benefit-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-card-hover); }
  .sa-page-benefit-card__icon-wrap { width: 3em; height: 3em; display: flex; align-items: center; justify-content: center; background: rgba(0,200,232,0.08); border-radius: var(--radius-md); margin-bottom: 1.25em; color: var(--color-primary); }
  .sa-page-benefit-card__title { font-family: var(--font-heading); font-size: 1.125em; font-weight: 700; line-height: 1.3; color: var(--color-text-white); margin-bottom: 0.5em; }
  .sa-page-benefit-card__desc { font-size: 0.875em; line-height: 1.6; color: var(--color-text-secondary); }

  /* Feature Image */
  .sa-page-feature-image { width: 100%; background-color: var(--color-bg-dark); padding-block: 3em 6em; }
  .sa-page-feature-image__inner { max-width: var(--max-width); margin: 0 auto; }
  .sa-page-feature-image__img { width: 100%; height: 24em; object-fit: cover; border-radius: var(--radius-lg); border: 1px solid var(--color-border); display: block; }

  /* Accordion */
  .sa-page-included { width: 100%; background-color: var(--color-bg-dark); padding-block: 6.25em; }
  .sa-page-included__inner { display: flex; gap: 3.75em; }
  .sa-page-included__left { flex: 1; }
  .sa-page-included__left .section-label { display: block; margin-bottom: 0.75em; }
  .sa-page-included__heading { font-family: var(--font-heading); font-size: 2.75em; font-weight: 800; line-height: 1.15; color: var(--color-text-white); margin-bottom: 0.5em; }
  .sa-page-included__desc { font-size: 1em; line-height: 1.6; color: var(--color-text-secondary); max-width: 28em; margin-bottom: 2em; }
  .sa-page-included__right { flex: 1; }
  .sa-page-accordion { display: flex; flex-direction: column; gap: 0.75em; }
  .sa-page-accordion__item { border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; background-color: var(--color-bg-surface); transition: border-color var(--transition-base); }
  .sa-page-accordion__item--active { border-color: var(--color-primary); }
  .sa-page-accordion__header { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 1.25em; background: none; border: none; cursor: pointer; font: inherit; color: inherit; }
  .sa-page-accordion__header-left { display: flex; align-items: center; gap: 0.75em; }
  .sa-page-accordion__icon-svg { width: 1.25em; height: 1.25em; flex-shrink: 0; color: var(--color-primary); }
  .sa-page-accordion__title { font-family: var(--font-heading); font-size: 0.8125em; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--color-text-white); }
  .sa-page-accordion__toggle { display: flex; align-items: center; justify-content: center; width: 2.5em; height: 2.5em; background-color: var(--color-bg-dark); border-radius: var(--radius-md); flex-shrink: 0; color: var(--color-primary); }
  .sa-page-accordion__body { padding: 0 1.25em 1.25em; }
  .sa-page-accordion__text { font-size: 0.875em; line-height: 1.6; color: var(--color-text-secondary); padding-left: 2.25em; }
  .sa-page-accordion__text a { color: var(--color-primary); font-weight: 600; }

  /* CTA Banner */
  .sa-page-cta-banner { width: 100%; background-color: var(--color-bg-dark); background-image: url('/assets/images/hero-cta.jpg'); background-size: cover; background-position: center; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding-block: 5em; position: relative; }
  .sa-page-cta-banner::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,15,20,0.88) 0%, rgba(10,15,20,0.94) 100%); pointer-events: none; }
  .sa-page-cta-banner__inner { text-align: center; position: relative; z-index: 1; }
  .sa-page-cta-banner__heading { font-family: var(--font-heading); font-size: 2.5em; font-weight: 800; color: var(--color-text-white); margin-bottom: 0.5em; }
  .sa-page-cta-banner__text { font-size: 1.0625em; line-height: 1.6; color: var(--color-text-secondary); max-width: 36em; margin-inline: auto; margin-bottom: 2em; }
  .sa-page-cta-banner__actions { display: flex; gap: 1em; justify-content: center; flex-wrap: wrap; }

  /* Responsive */
  @media (max-width: 991px) {
    .sa-page-hero__heading { font-size: 2.75em; }
    .sa-page-hero__stats { flex-wrap: wrap; gap: 2em; }
    .sa-page-benefits__grid { max-width: 100%; }
    .sa-page-included__inner { flex-direction: column; gap: 2.5em; }
    .sa-page-included__left { text-align: center; }
    .sa-page-included__desc { max-width: 100%; }
    .sa-page-included__cta { display: flex; justify-content: center; }
