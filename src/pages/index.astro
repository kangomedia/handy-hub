---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Elite Property Innovations | Home Improvement & Remodeling in Westminster, CO"
  description="Westminster's trusted home improvement contractor. Kitchen & bath remodeling, painting, carpentry, roofing & more. 25+ years experience. Free estimates — call (720) 299-1238."
>
  <Navbar variant="dark" />

  <main id="main-content">

    <!-- ============================== HERO ============================== -->
    <section class="hero" id="hero">
      <div class="hero__gradient" aria-hidden="true"></div>
      <div class="hero__grid-overlay" aria-hidden="true"></div>
      <div class="hero__inner container">
        <div class="hero__content">
          <div class="hero__text" data-animate>
            <span class="hero__eyebrow section-label">Elite Property Innovations</span>
            <h1 class="hero__heading">Quality Home Improvements in Westminster & the Denver Metro</h1>
            <p class="hero__subtext">From kitchen remodels to custom carpentry, we deliver craftsmanship you can rely on. Over 25 years of hands-on experience transforming Colorado homes — with integrity, precision, and care.</p>
            <div class="hero__badges">
              <div class="hero__badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>25+ Years Experience</span>
              </div>
              <div class="hero__badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <span>5-Star Google Rated</span>
              </div>
              <div class="hero__badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Locally Owned & Operated</span>
              </div>
            </div>
            <div class="hero__ctas">
              <a href="/contact" class="btn btn--accent">Get Your Free Estimate</a>
              <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
            </div>
          </div>
          <div class="hero__form-wrapper" data-animate>
            <div class="hero__form-card">
              <h2 class="hero__form-title">Request a Free Quote</h2>
              <p class="hero__form-subtitle">We respond within 60 seconds — even after hours.</p>
              <form class="hero__form" action="#" method="post">
                <input type="text" name="name" class="hero__form-input" placeholder="Full Name" required aria-label="Full Name" />
                <input type="tel" name="phone" class="hero__form-input" placeholder="Phone Number" required aria-label="Phone Number" />
                <input type="email" name="email" class="hero__form-input" placeholder="Email Address" aria-label="Email Address" />
                <select name="service" class="hero__form-input hero__form-select" aria-label="Select service">
                  <option value="" disabled selected>Select a Service</option>
                  <option value="kitchen-remodeling">Kitchen Remodeling</option>
                  <option value="bathroom-remodeling">Bathroom Remodeling</option>
                  <option value="painting">Interior & Exterior Painting</option>
                  <option value="handyman">Handyman Services</option>
                  <option value="drywall">Drywall Services</option>
                  <option value="carpentry">Carpentry</option>
                  <option value="deck-construction">Deck Construction & Repair</option>
                  <option value="fencing">Fence Installation & Repair</option>
                  <option value="windows-doors">Window & Door Replacement</option>
                  <option value="roofing">Roofing Services</option>
                </select>
                <textarea name="description" class="hero__form-input hero__form-textarea" placeholder="Tell us about your project..." rows="3" aria-label="Project description"></textarea>
                <button type="submit" class="btn btn--accent hero__form-submit">Get My Free Estimate</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== TRUST STRIP ============================== -->
    <section class="trust-strip" data-animate>
      <div class="trust-strip__inner container">
        <div class="trust-strip__google">
          <div class="trust-strip__stars">
            {[1,2,3,4,5].map(() => (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </div>
          <span class="trust-strip__rating"><strong>5.0</strong> on Google</span>
        </div>
        <span class="trust-strip__divider" aria-hidden="true"></span>
        <p class="trust-strip__text">Trusted by homeowners across Westminster, Arvada, Broomfield & beyond</p>
        <a href="https://www.google.com/maps/place/Elite+Property+Innovations+LLC" class="trust-strip__link" target="_blank" rel="noopener">Read our reviews →</a>
      </div>
    </section>

    <!-- ============================== SERVICES ============================== -->
    <section class="services" id="services">
      <div class="services__inner container">
        <span class="services__eyebrow section-label" data-animate>What We Do</span>
        <h2 class="services__heading" data-animate>Home Improvement Services in Westminster, CO</h2>
        <p class="services__subtext" data-animate>From full-scale remodels to everyday repairs, our skilled team delivers lasting results. Every project is backed by 25+ years of construction expertise and a commitment to doing things the right way.</p>

        <div class="services__grid">
          <!-- 1. Kitchen Remodeling -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9h18"/><path d="M3 15h18"/><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg>
            </div>
            <h3 class="services__card-title">Kitchen Remodeling</h3>
            <p class="services__card-desc">Cabinet installation, lighting upgrades, countertops, and modern design updates tailored to your lifestyle and budget.</p>
            <a href="/services/kitchen-remodeling" class="services__card-link">Learn More →</a>
          </div>

          <!-- 2. Bathroom Remodeling -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg viewBox="0 0 32 32" fill="currentColor" width="32" height="32"><path d="M22.6673 2.66602C23.6876 2.66596 24.6693 3.05578 25.4117 3.75573C26.154 4.45567 26.6008 5.41282 26.6607 6.43135L26.6673 6.66602C27.7282 6.66602 28.7456 7.08744 29.4957 7.83759C30.2459 8.58773 30.6673 9.60515 30.6673 10.666C30.6674 12.7359 29.8652 14.7252 28.4294 16.216C26.9935 17.7068 25.0357 18.5831 22.9673 18.6607L22.6673 18.666H17.334L17.534 18.6727C18.1689 18.7204 18.7658 18.9937 19.2167 19.4432C19.6676 19.8926 19.9429 20.4886 19.9927 21.1233L20.0007 21.3327V26.666C20.0009 27.3388 19.7468 27.9868 19.2893 28.4801C18.8319 28.9734 18.2049 29.2756 17.534 29.326L17.334 29.3327H14.6673C13.9945 29.3329 13.3466 29.0788 12.8533 28.6214C12.3599 28.1639 12.0578 27.5369 12.0073 26.866L12.0007 26.666V21.3327C12.0004 20.6599 12.2545 20.0119 12.712 19.5186C13.1694 19.0253 13.7964 18.7231 14.4673 18.6727L14.6673 18.666V17.3327C14.6674 17.0061 14.7873 16.6909 15.0043 16.4469C15.2213 16.2028 15.5203 16.0469 15.8447 16.0087L16.0007 15.9993H22.6673C24.0818 15.9993 25.4384 15.4374 26.4386 14.4373C27.4387 13.4371 28.0007 12.0805 28.0007 10.666C28.0006 10.3394 27.8807 10.0242 27.6637 9.78019C27.4467 9.53614 27.1477 9.38022 26.8233 9.34202L26.6673 9.33268L26.6607 9.56735C26.6032 10.5455 26.1888 11.4685 25.496 12.1613C24.8031 12.8541 23.8801 13.2686 22.902 13.326L22.6673 13.3327H9.33398C8.3137 13.3327 7.33196 12.9429 6.58964 12.243C5.84731 11.543 5.40051 10.5859 5.34065 9.56735L5.33398 9.33268V6.66602C5.33393 5.64573 5.72375 4.664 6.4237 3.92167C7.12364 3.17934 8.08079 2.73254 9.09932 2.67268L9.33398 2.66602H22.6673Z"/></svg>
            </div>
            <h3 class="services__card-title">Bathroom Remodeling</h3>
            <p class="services__card-desc">Shower and tile installation, vanity replacements, lighting improvements, and full bathroom transformations.</p>
            <a href="/services/bathroom-remodeling" class="services__card-link">Learn More →</a>
          </div>

          <!-- 3. Interior & Exterior Painting -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg viewBox="0 0 32 32" fill="currentColor" width="32" height="32"><path d="M22.6673 2.66602C23.6876 2.66596 24.6693 3.05578 25.4117 3.75573C26.154 4.45567 26.6008 5.41282 26.6607 6.43135L26.6673 6.66602C27.7282 6.66602 28.7456 7.08744 29.4957 7.83759C30.2459 8.58773 30.6673 9.60515 30.6673 10.666C30.6674 12.7359 29.8652 14.7252 28.4294 16.216C26.9935 17.7068 25.0357 18.5831 22.9673 18.6607L22.6673 18.666H17.334L17.534 18.6727C18.1689 18.7204 18.7658 18.9937 19.2167 19.4432C19.6676 19.8926 19.9429 20.4886 19.9927 21.1233L20.0007 21.3327V26.666C20.0009 27.3388 19.7468 27.9868 19.2893 28.4801C18.8319 28.9734 18.2049 29.2756 17.534 29.326L17.334 29.3327H14.6673C13.9945 29.3329 13.3466 29.0788 12.8533 28.6214C12.3599 28.1639 12.0578 27.5369 12.0073 26.866L12.0007 26.666V21.3327C12.0004 20.6599 12.2545 20.0119 12.712 19.5186C13.1694 19.0253 13.7964 18.7231 14.4673 18.6727L14.6673 18.666V17.3327C14.6674 17.0061 14.7873 16.6909 15.0043 16.4469C15.2213 16.2028 15.5203 16.0469 15.8447 16.0087L16.0007 15.9993H22.6673C24.0818 15.9993 25.4384 15.4374 26.4386 14.4373C27.4387 13.4371 28.0007 12.0805 28.0007 10.666C28.0006 10.3394 27.8807 10.0242 27.6637 9.78019C27.4467 9.53614 27.1477 9.38022 26.8233 9.34202L26.6673 9.33268L26.6607 9.56735C26.6032 10.5455 26.1888 11.4685 25.496 12.1613C24.8031 12.8541 23.8801 13.2686 22.902 13.326L22.6673 13.3327H9.33398C8.3137 13.3327 7.33196 12.9429 6.58964 12.243C5.84731 11.543 5.40051 10.5859 5.34065 9.56735L5.33398 9.33268V6.66602C5.33393 5.64573 5.72375 4.664 6.4237 3.92167C7.12364 3.17934 8.08079 2.73254 9.09932 2.67268L9.33398 2.66602H22.6673Z"/></svg>
            </div>
            <h3 class="services__card-title">Interior & Exterior Painting</h3>
            <p class="services__card-desc">Professional painting services that refresh walls, ceilings, trim, and exteriors with clean, lasting results.</p>
            <a href="/services/painting" class="services__card-link">Learn More →</a>
          </div>

          <!-- 4. Handyman Services -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg viewBox="0 0 32 32" fill="currentColor" width="32" height="32"><path d="M17.6048 3.8144C17.1643 3.41861 16.593 3.19967 16.0008 3.19967C15.4086 3.19967 14.8373 3.41861 14.3968 3.8144L5.5968 11.7232C5.3461 11.9482 5.14559 12.2235 5.00831 12.5312C4.87103 12.8388 4.80005 13.1719 4.8 13.5088V24.8C4.8 25.4365 5.05286 26.047 5.50294 26.4971C5.95303 26.9471 6.56348 27.2 7.2 27.2H24.8C25.4365 27.2 26.047 26.9471 26.4971 26.4971C26.9471 26.047 27.2 25.4365 27.2 24.8V13.5088C27.2001 13.172 27.1294 12.839 26.9924 12.5314C26.8554 12.2237 26.6552 11.9484 26.4048 11.7232L17.6048 3.8144ZM11.2 17.6C10.7757 17.6 10.3687 17.4314 10.0686 17.1314C9.76857 16.8313 9.6 16.4243 9.6 16C9.6 15.5757 9.76857 15.1687 10.0686 14.8686C10.3687 14.5686 10.7757 14.4 11.2 14.4C11.6243 14.4 12.0313 14.5686 12.3314 14.8686C12.6314 15.1687 12.8 15.5757 12.8 16C12.8 16.4243 12.6314 16.8313 12.3314 17.1314C12.0313 17.4314 11.6243 17.6 11.2 17.6ZM17.6 16C17.6 16.4243 17.4314 16.8313 17.1314 17.1314C16.8313 17.4314 16.4243 17.6 16 17.6C15.5757 17.6 15.1687 17.4314 14.8686 17.1314C14.5686 16.8313 14.4 16.4243 14.4 16C14.4 15.5757 14.5686 15.1687 14.8686 14.8686C15.1687 14.5686 15.5757 14.4 16 14.4C16.4243 14.4 16.8313 14.5686 17.1314 14.8686C17.4314 15.1687 17.6 15.5757 17.6 16ZM20.8 17.6C20.3757 17.6 19.9687 17.4314 19.6686 17.1314C19.3686 16.8313 19.2 16.4243 19.2 16C19.2 15.5757 19.3686 15.1687 19.6686 14.8686C19.9687 14.5686 20.3757 14.4 20.8 14.4C21.2243 14.4 21.6313 14.5686 21.9314 14.8686C22.2314 15.1687 22.4 15.5757 22.4 16C22.4 16.4243 22.2314 16.8313 21.9314 17.1314C21.6313 17.4314 21.2243 17.6 20.8 17.6ZM12.8 20.8C12.8 21.2243 12.6314 21.6313 12.3314 21.9314C12.0313 22.2314 11.6243 22.4 11.2 22.4C10.7757 22.4 10.3687 22.2314 10.0686 21.9314C9.76857 21.6313 9.6 21.2243 9.6 20.8C9.6 20.3757 9.76857 19.9687 10.0686 19.6686C10.3687 19.3686 10.7757 19.2 11.2 19.2C11.6243 19.2 12.0313 19.3686 12.3314 19.6686C12.6314 19.9687 12.8 20.3757 12.8 20.8ZM16 22.4C15.5757 22.4 15.1687 22.2314 14.8686 21.9314C14.5686 21.6313 14.4 21.2243 14.4 20.8C14.4 20.3757 14.5686 19.9687 14.8686 19.6686C15.1687 19.3686 15.5757 19.2 16 19.2C16.4243 19.2 16.8313 19.3686 17.1314 19.6686C17.4314 19.9687 17.6 20.3757 17.6 20.8C17.6 21.2243 17.4314 21.6313 17.1314 21.9314C16.8313 22.2314 16.4243 22.4 16 22.4ZM22.4 20.8C22.4 21.2243 22.2314 21.6313 21.9314 21.9314C21.6313 22.2314 21.2243 22.4 20.8 22.4C20.3757 22.4 19.9687 22.2314 19.6686 21.9314C19.3686 21.6313 19.2 21.2243 19.2 20.8C19.2 20.3757 19.3686 19.9687 19.6686 19.6686C19.9687 19.3686 20.3757 19.2 20.8 19.2C21.2243 19.2 21.6313 19.3686 21.9314 19.6686C22.2314 19.9687 22.4 20.3757 22.4 20.8Z"/></svg>
            </div>
            <h3 class="services__card-title">Handyman Services</h3>
            <p class="services__card-desc">Repairs, furniture assembly, seasonal maintenance, and small home projects handled efficiently and reliably.</p>
            <a href="/services/handyman" class="services__card-link">Learn More →</a>
          </div>

          <!-- 5. Drywall Services -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg viewBox="0 0 32 32" fill="currentColor" width="32" height="32"><path d="M4 29.3333V26.6667H8.66667V20.6667H14.6667V14.6667H20.6667V8.66667H26.6667V4H29.3333V11.3333H23.3333V17.3333H17.3333V23.3333H11.3333V29.3333H4Z"/></svg>
            </div>
            <h3 class="services__card-title">Drywall Services</h3>
            <p class="services__card-desc">Installation, repair, texture matching, and water damage restoration for flawless, paint-ready walls and ceilings.</p>
            <a href="/services/drywall" class="services__card-link">Learn More →</a>
          </div>

          <!-- 6. Carpentry -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg viewBox="0 0 32 32" fill="currentColor" width="32" height="32"><path d="M26.3065 18.9724L9.33315 1.99902L4.14648 7.18569L14.9865 22.7457C13.9465 23.7857 13.9465 25.479 14.9865 26.519L16.8665 28.399C17.9065 29.439 19.5998 29.439 20.6398 28.399L26.2931 22.7457C27.3465 21.7057 27.3465 20.0124 26.3065 18.9724ZM18.7598 26.5057L16.8798 24.6257L22.5331 18.9724L24.4131 20.8524L18.7598 26.5057Z"/></svg>
            </div>
            <h3 class="services__card-title">Carpentry</h3>
            <p class="services__card-desc">Custom woodwork, trim installation, door replacements, and framing to elevate both style and structural integrity.</p>
            <a href="/services/carpentry" class="services__card-link">Learn More →</a>
          </div>

          <!-- 7. Deck Construction -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="12" width="20" height="10" rx="1"/><path d="M2 17h20"/><path d="M7 12V2"/><path d="M17 12V2"/><path d="M2 7h20"/></svg>
            </div>
            <h3 class="services__card-title">Deck Construction & Repair</h3>
            <p class="services__card-desc">New deck builds, repairs, and seasonal maintenance for durable, attractive outdoor living spaces.</p>
            <a href="/services/deck-construction" class="services__card-link">Learn More →</a>
          </div>

          <!-- 8. Fence Installation -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 3v18"/><path d="M12 3v18"/><path d="M20 3v18"/><path d="M2 8h6"/><path d="M10 8h6"/><path d="M18 8h4"/><path d="M2 16h6"/><path d="M10 16h6"/><path d="M18 16h4"/><path d="M4 3l-2 3"/><path d="M4 3l2 3"/><path d="M12 3l-2 3"/><path d="M12 3l2 3"/><path d="M20 3l-2 3"/><path d="M20 3l2 3"/></svg>
            </div>
            <h3 class="services__card-title">Fence Installation & Repair</h3>
            <p class="services__card-desc">Wood, vinyl, chain-link, and ornamental fencing to enhance privacy, security, and curb appeal.</p>
            <a href="/services/fencing" class="services__card-link">Learn More →</a>
          </div>

          <!-- 9. Window & Door Replacement -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg viewBox="0 0 32 32" fill="currentColor" width="32" height="32"><path d="M17.3333 17.3333H28V25.3333C28 26.0667 27.7391 26.6947 27.2173 27.2173C26.6956 27.74 26.0676 28.0009 25.3333 28H17.3333V17.3333ZM17.3333 14.6667V4H25.3333C26.0667 4 26.6947 4.26133 27.2173 4.784C27.74 5.30667 28.0009 5.93422 28 6.66667V14.6667H17.3333ZM14.6667 14.6667H4V6.66667C4 5.93333 4.26133 5.30578 4.784 4.784C5.30667 4.26222 5.93422 4.00089 6.66667 4H14.6667V14.6667ZM14.6667 17.3333V28H6.66667C5.93333 28 5.30578 27.7391 4.784 27.2173C4.26222 26.6956 4.00089 26.0676 4 25.3333V17.3333H14.6667Z"/></svg>
            </div>
            <h3 class="services__card-title">Window & Door Replacement</h3>
            <p class="services__card-desc">Energy-efficient windows and doors for improved comfort, security, and style throughout your home.</p>
            <a href="/services/windows-doors" class="services__card-link">Learn More →</a>
          </div>

          <!-- 10. Roofing Services -->
          <div class="services__card" data-animate>
            <div class="services__card-icon">
              <svg viewBox="0 0 32 32" fill="currentColor" width="32" height="32"><path d="M30.895 15.5525L25.895 5.5525C25.8119 5.38636 25.6841 5.24666 25.526 5.14908C25.3679 5.05149 25.1858 4.99987 25 5H7C6.81422 4.99987 6.63208 5.05149 6.47399 5.14908C6.31591 5.24666 6.18814 5.38636 6.105 5.5525L1.105 15.5525C1.03616 15.6916 1.00023 15.8448 1 16V23C1 23.5304 1.21071 24.0391 1.58579 24.4142C1.96086 24.7893 2.46957 25 3 25H29C29.5304 25 30.0391 24.7893 30.4142 24.4142C30.7893 24.0391 31 23.5304 31 23V16C30.9998 15.8448 30.9638 15.6916 30.895 15.5525ZM12.3825 7L13.8825 10H10.1175L8.6175 7H12.3825ZM18.3825 7L19.8825 10H16.1175L14.6175 7H18.3825ZM12.6175 15L11.1175 12H14.8825L16.3825 15H12.6175ZM18.6175 15L17.1175 12H20.8825L22.3825 15H18.6175ZM24.6175 15L23.1175 12H26.8825L28.3825 15H24.6175ZM25.8825 10H22.1175L20.6175 7H24.3825L25.8825 10ZM13 23V17H29V23H13Z"/></svg>
            </div>
            <h3 class="services__card-title">Roofing Services</h3>
            <p class="services__card-desc">New roof installation, repairs, and maintenance for lasting protection against Colorado's weather.</p>
            <a href="/services/roofing" class="services__card-link">Learn More →</a>
          </div>
        </div>

        <div class="services__cta" data-animate>
          <a href="/services" class="btn btn--outline">View All Services</a>
        </div>
      </div>
    </section>

    <!-- ============================== WHY CHOOSE US ============================== -->
    <section class="why" id="why-us">
      <div class="why__inner container">
        <div class="why__header" data-animate>
          <span class="why__eyebrow section-label">Why Choose Us</span>
          <h2 class="why__heading">Built on Experience, Reliability & Attention to Detail</h2>
          <p class="why__subtext">With over two decades in construction, our team delivers home improvement results that last. Every project — big or small — is approached with precision and a commitment to exceeding your expectations.</p>
        </div>
        <div class="why__grid">
