---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="HandyHub — Your Trusted Partner for Home Maintenance" description="From fixing leaks to full maintenance, our trusted professionals ensure your home is always in top shape.">
  <Navbar variant="dark" />

  <main id="main-content">

    <!-- ============================== HERO ============================== -->
    <section class="hero">
      <img
        src="/assets/images/hero-bg-vectors.png"
        alt=""
        role="presentation"
        class="hero__bg"
        width="1440"
        height="864"
      />
      <div class="hero__inner container">
        <div class="hero__content">
          <div class="hero__text">
            <span class="hero__eyebrow section-label">HANDYHUB</span>
            <h1 class="hero__heading">Your trusted partner for home maintenance</h1>
            <p class="hero__subtext">From fixing leaks to full maintenance, our trusted professionals ensure your home is always in top shape.</p>
            <a href="/contact" class="btn btn--light">Contact us</a>
          </div>
          <div class="hero__image-wrapper">
            <img
              src="/assets/images/hero-home.jpg"
              alt="Professional handyman working on home maintenance"
              width="600"
              height="700"
              class="hero__image"
            />
          </div>
        </div>
        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-number">10y</span>
            <span class="hero__stat-label section-label">EXPEREINCES</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-number">100+</span>
            <span class="hero__stat-label section-label">TEAM MEMBERS</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-number">1k</span>
            <span class="hero__stat-label section-label">PROJECTS</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== ABOUT ============================== -->
    <section class="about">
      <div class="about__inner container">
        <span class="about__eyebrow section-label">HANDYHUB</span>
        <h2 class="about__heading">
          <span class="about__heading--gray">A statement about Handyman's </span><span class="about__heading--dark">dedication to quality, reliability, and customer satisfaction.</span>
        </h2>
        <div class="about__row">
          <a href="/about" class="btn">Learn more</a>
          <p class="about__description">Introduce the team, focusing on their experience and commitment to delivering top-notch services. Including real team photos can build trust.</p>
        </div>
      </div>
    </section>

    <!-- ============================== SERVICES ============================== -->
    <section class="services">
      <div class="services__inner container">
        <span class="services__eyebrow section-label">HANDYHUB</span>
        <h2 class="services__heading">Quality handyman solutions</h2>
        <p class="services__subtext">At QuickFix, we offer a comprehensive range of handyman services to keep your home in top condition. Whether it's a minor repair or a major project, our skilled team is here to help.</p>

        <div class="services__grid">
          <div class="services__card">
            <img src="/assets/images/icon-home-repair.svg" alt="" role="presentation" width="32" height="32" class="services__card-icon" />
            <h3 class="services__card-title">Home Repairs</h3>
            <p class="services__card-desc">Quick and reliable repair services for all your household needs, from fixing leaky faucets to patching drywall.</p>
            <a href="/services" class="services__card-link">LEARN MORE &rarr;</a>
          </div>
          <div class="services__card">
            <img src="/assets/images/icon-paint.svg" alt="" role="presentation" width="32" height="32" class="services__card-icon" />
            <h3 class="services__card-title">Decorating service</h3>
            <p class="services__card-desc">Transform your space with our professional painting and decorating services, tailored to your style and preferences.</p>
            <a href="/services" class="services__card-link">LEARN MORE &rarr;</a>
          </div>
          <div class="services__card">
            <img src="/assets/images/icon-plumbing.svg" alt="" role="presentation" width="32" height="32" class="services__card-icon" />
            <h3 class="services__card-title">Plumbing Services</h3>
            <p class="services__card-desc">From dripping taps to full plumbing installations, our experts handle it all with precision and care.</p>
            <a href="/services" class="services__card-link">LEARN MORE &rarr;</a>
          </div>
          <div class="services__card">
            <img src="/assets/images/icon-electrical.svg" alt="" role="presentation" width="32" height="32" class="services__card-icon" />
            <h3 class="services__card-title">Electrical Work</h3>
            <p class="services__card-desc">Safe and professional electrical services, including wiring, lighting installation, and troubleshooting.</p>
            <a href="/services" class="services__card-link">LEARN MORE &rarr;</a>
          </div>
          <div class="services__card">
            <img src="/assets/images/icon-carpentry.svg" alt="" role="presentation" width="32" height="32" class="services__card-icon" />
            <h3 class="services__card-title">Carpentry Services</h3>
            <p class="services__card-desc">Custom carpentry solutions for shelving, cabinetry, doors, and more, crafted with skill and attention to detail.</p>
            <a href="/services" class="services__card-link">LEARN MORE &rarr;</a>
          </div>
          <div class="services__card">
            <img src="/assets/images/icon-furniture.svg" alt="" role="presentation" width="32" height="32" class="services__card-icon" />
            <h3 class="services__card-title">Furniture Assembly</h3>
            <p class="services__card-desc">Fast and efficient furniture assembly services, so you can enjoy your new furniture without the hassle.</p>
            <a href="/services" class="services__card-link">LEARN MORE &rarr;</a>
          </div>
        </div>

        <div class="services__cta">
          <a href="/services" class="btn">View all services</a>
        </div>
      </div>
    </section>

    <!-- ============================== CTA ============================== -->
    <section class="cta">
      <img
        src="/assets/images/hero-bg-vectors.png"
        alt=""
        role="presentation"
        class="cta__bg"
        width="1440"
        height="864"
      />
      <div class="cta__inner container">
        <span class="cta__eyebrow section-label">HANDYHUB</span>
        <h2 class="cta__heading">Fast, reliable, and affordable home maintenance solutions</h2>
        <a href="/contact" class="btn btn--light">Contact us</a>
        <div class="cta__image-wrapper">
          <img
            src="/assets/images/hero-cta.jpg"
            alt="Professional home maintenance team at work"
            width="1200"
            height="600"
            class="cta__image"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- ============================== TESTIMONIALS ============================== -->
    <section class="testimonials">
      <div class="testimonials__inner container">
        <span class="testimonials__eyebrow section-label">HANDYHUB</span>
        <h2 class="testimonials__heading">What our customers are saying</h2>

        <div class="testimonials__grid">
          <div class="testimonials__card">
            <div class="testimonials__card-image-wrapper">
              <img src="/assets/images/testimonial-1.jpg" alt="Maria Onana" width="376" height="180" class="testimonials__card-image" loading="lazy" />
            </div>
            <div class="testimonials__card-content">
              <h3 class="testimonials__card-title">Fantastic work!</h3>
              <p class="testimonials__card-quote">I needed a few small repairs done around the house, and Handyhub was fantastic!</p>
              <span class="testimonials__card-name">MARIA ONANA</span>
            </div>
          </div>
          <div class="testimonials__card">
            <div class="testimonials__card-image-wrapper">
              <img src="/assets/images/testimonial-2.jpg" alt="David Alaba" width="376" height="180" class="testimonials__card-image" loading="lazy" />
            </div>
            <div class="testimonials__card-content">
              <h3 class="testimonials__card-title">Excellent Work!</h3>
              <p class="testimonials__card-quote">The team was knowledgeable, courteous, and completed the job efficiently.</p>
              <span class="testimonials__card-name">DAVID ALABA</span>
            </div>
          </div>
          <div class="testimonials__card">
            <div class="testimonials__card-image-wrapper">
              <img src="/assets/images/testimonial-3.jpg" alt="Lawkey Nova" width="376" height="180" class="testimonials__card-image" loading="lazy" />
            </div>
            <div class="testimonials__card-content">
              <h3 class="testimonials__card-title">well done!</h3>
              <p class="testimonials__card-quote">The team was knowledgeable, courteous, and completed the job efficiently.</p>
              <span class="testimonials__card-name">LAWKEY NOVA</span>
            </div>
          </div>
          <div class="testimonials__card">
            <div class="testimonials__card-image-wrapper">
              <img src="/assets/images/testimonial-4.jpg" alt="David Alaba" width="376" height="180" class="testimonials__card-image" loading="lazy" />
            </div>
            <div class="testimonials__card-content">
              <h3 class="testimonials__card-title">Excellent Work!</h3>
              <p class="testimonials__card-quote">The team was knowledgeable, courteous, and completed the job efficiently.</p>
              <span class="testimonials__card-name">DAVID ALABA</span>
            </div>
          </div>
        </div>

        <div class="testimonials__nav">
          <button class="testimonials__nav-btn" type="button" aria-label="Previous testimonial">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 15L7 10L12 5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="testimonials__nav-btn" type="button" aria-label="Next testimonial">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 5L13 10L8 15" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </section>

    <!-- ============================== TEAMS ============================== -->
    <section class="teams">
      <img
        src="/assets/images/bg-team-home.png"
        alt=""
        role="presentation"
        class="teams__bg"
        width="1440"
        height="800"
      />
      <div class="teams__inner container">
        <div class="teams__sidebar">
          <span class="teams__eyebrow section-label">HANDYHUB</span>
          <h2 class="teams__heading">Meet Our Team</h2>
          <p class="teams__description">Our team of skilled professionals is dedicated to providing the highest quality handyman services.</p>
          <div class="teams__stat">
            <span class="teams__stat-number">100+</span>
            <span class="teams__stat-label section-label">TEAM MEMBERS</span>
          </div>
        </div>
        <div class="teams__grid">
          <div class="teams__member">
            <img src="/assets/images/team-member-1.jpg" alt="Ronie vonie" width="300" height="306" class="teams__member-image" loading="lazy" />
            <h3 class="teams__member-name">Ronie vonie</h3>
            <p class="teams__member-role">Founder & Lead Handyman</p>
          </div>
          <div class="teams__member">
            <img src="/assets/images/team-member-2.jpg" alt="Bowie david" width="300" height="306" class="teams__member-image" loading="lazy" />
            <h3 class="teams__member-name">Bowie david</h3>
            <p class="teams__member-role">Founder & Lead Handyman</p>
          </div>
          <div class="teams__member">
            <img src="/assets/images/team-member-3.jpg" alt="Andrea davis" width="300" height="306" class="teams__member-image" loading="lazy" />
            <h3 class="teams__member-name">Andrea davis</h3>
            <p class="teams__member-role">Founder & Lead Handyman</p>
          </div>
          <div class="teams__member">
            <img src="/assets/images/team-member-4.jpg" alt="Noel javier" width="300" height="306" class="teams__member-image" loading="lazy" />
            <h3 class="teams__member-name">Noel javier</h3>
            <p class="teams__member-role">Founder & Lead Handyman</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== CONTACT ============================== -->
    <section class="contact">
      <div class="contact__inner container">
        <div class="contact__left">
          <span class="contact__eyebrow section-label">HANDYHUB</span>
          <h2 class="contact__heading">Get in touch with us today</h2>
          <img
            src="/assets/images/contact-image.jpg"
            alt="HandyHub team ready to help"
            width="600"
            height="306"
            class="contact__image"
            loading="lazy"
          />
        </div>
        <div class="contact__right">
          <form class="contact__form" action="#" method="post">
            <div class="contact__field">
              <label for="full-name" class="contact__label">Full Name</label>
              <input type="text" id="full-name" name="full-name" class="contact__input" placeholder="Enter your full name" required />
            </div>
            <div class="contact__field">
              <label for="phone" class="contact__label">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="contact__input" placeholder="Enter your phone number" />
            </div>
            <div class="contact__field">
              <label for="service" class="contact__label">Select Services</label>
              <div class="contact__select-wrapper">
                <select id="service" name="service" class="contact__input contact__select">
                  <option value="" disabled selected>Select a service</option>
                  <option value="home-repairs">Home Repairs</option>
                  <option value="decorating">Decorating Service</option>
                  <option value="plumbing">Plumbing Services</option>
                  <option value="electrical">Electrical Work</option>
                  <option value="carpentry">Carpentry Services</option>
                  <option value="furniture">Furniture Assembly</option>
                </select>
              </div>
            </div>
            <div class="contact__field">
              <label for="message" class="contact__label">Your message</label>
              <textarea id="message" name="message" class="contact__input contact__textarea" placeholder="Write your message here" rows="5"></textarea>
            </div>
            <button type="submit" class="btn contact__submit">Submit</button>
          </form>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ====================================================================
     HERO
     ==================================================================== */
  .hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    position: relative;
    overflow: hidden;
    min-height: 54em;
  }

  .hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    opacity: 0.3;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    padding-block: 4em 3em;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 54em;
  }

  .hero__content {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3em;
    flex: 1;
  }

  .hero__text {
    max-width: 36em;
    display: flex;
    flex-direction: column;
    gap: 1.5em;
    padding-top: 4em;
  }

  .hero__eyebrow {
    font-size: 0.875em;
    letter-spacing: 2.8px;
    color: var(--color-text-white);
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -1.2px;
    color: var(--color-text-white);
    max-width: 12.77em; /* ~479px at 3.75em */
  }

  .hero__subtext {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-white);
    max-width: 27.8em;
  }

  .hero__image-wrapper {
    flex-shrink: 0;
    width: 36em;
    height: 40em;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: 6em;
    padding-top: 3em;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .hero__stat-number {
    font-family: var(--font-heading);
    font-size: 3em;
    font-weight: 400;
    line-height: 1.167;
    letter-spacing: -0.96px;
    color: var(--color-text-white);
  }

  .hero__stat-label {
    font-size: 0.875em;
    letter-spacing: 2.8px;
    color: var(--color-text-white);
  }

  /* Hero responsive */
  @media (max-width: 991px) {
    .hero {
      min-height: auto;
    }

    .hero__inner {
      min-height: auto;
      padding-block: 3em 2em;
    }

    .hero__content {
      flex-direction: column;
    }

    .hero__text {
      max-width: 100%;
      padding-top: 2em;
    }

    .hero__image-wrapper {
      width: 100%;
      height: 28em;
    }

    .hero__stats {
      gap: 3em;
      flex-wrap: wrap;
    }
  }

  @media (max-width: 767px) {
    .hero__heading {
      max-width: 100%;
    }

    .hero__image-wrapper {
      height: 22em;
    }

    .hero__stats {
      gap: 2em;
    }

    .hero__stat-number {
      font-size: 2.25em;
    }
  }

  @media (max-width: 479px) {
    .hero__image-wrapper {
      height: 18em;
    }

    .hero__stats {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5em;
    }
  }

  /* ====================================================================
     ABOUT
     ==================================================================== */
  .about {
    width: 100%;
    background-color: var(--color-bg-white);
  }

  .about__inner {
    padding-block: 6.25em;
    display: flex;
    flex-direction: column;
    gap: 2em;
  }

  .about__eyebrow {
    color: var(--color-text-primary);
  }

  .about__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -1.2px;
  }

  .about__heading--gray {
    color: var(--color-text-gray);
  }

  .about__heading--dark {
    color: var(--color-text-primary);
  }

  .about__row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3em;
    margin-top: 1em;
  }

  .about__description {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 40.5em;
  }

  /* About responsive */
  @media (max-width: 991px) {
    .about__inner {
      padding-block: 4em;
    }

    .about__row {
      flex-direction: column;
      gap: 1.5em;
    }
  }

  @media (max-width: 767px) {
    .about__inner {
      padding-block: 3em;
    }

    .about__description {
      max-width: 100%;
    }
  }

  /* ====================================================================
     SERVICES
     ==================================================================== */
  .services {
    width: 100%;
    background-color: var(--color-bg-white);
  }

  .services__inner {
    padding-block: 7.5em;
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .services__eyebrow {
    color: var(--color-text-primary);
  }

  .services__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -1.2px;
    color: var(--color-text-primary);
  }

  .services__subtext {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 45em;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: 2em;
  }

  .services__card {
    display: flex;
    flex-direction: column;
    gap: 1em;
    padding: 2em;
    border: 1px solid var(--color-border);
    margin-right: -1px;
    margin-bottom: -1px;
  }

  .services__card-icon {
    width: 2em;
    height: 2em;
  }

  .services__card-title {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 3.2px;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .services__card-desc {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 400;
    line-height: 1.429;
    color: var(--color-text-secondary);
  }

  .services__card-link {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 500;
    line-height: 1.429;
    letter-spacing: 2.8px;
    text-transform: uppercase;
    text-decoration: underline;
    color: var(--color-text-primary);
    margin-top: auto;
  }

  .services__card-link:hover {
    opacity: 0.7;
  }

  .services__cta {
    margin-top: 2.5em;
  }

  /* Services responsive */
  @media (max-width: 991px) {
    .services__inner {
      padding-block: 5em;
    }

    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .services__inner {
      padding-block: 3em;
    }

    .services__grid {
      grid-template-columns: 1fr;
    }

    .services__card {
      margin-right: 0;
    }
  }

  /* ====================================================================
     CTA
     ==================================================================== */
  .cta {
    width: 100%;
    background-color: var(--color-bg-dark);
    position: relative;
    overflow: hidden;
  }

  .cta__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    opacity: 0.3;
  }

  .cta__inner {
    position: relative;
    z-index: 1;
    padding-top: 6.25em;
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .cta__eyebrow {
    font-size: 0.875em;
    letter-spacing: 2.8px;
    color: var(--color-text-white);
  }

  .cta__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -1.2px;
    color: var(--color-text-white);
    max-width: 18em;
  }

  .cta__image-wrapper {
    margin-top: 2em;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .cta__image {
    width: 100%;
    height: 37.5em;
    object-fit: cover;
  }

  /* CTA responsive */
  @media (max-width: 991px) {
    .cta__inner {
      padding-top: 4em;
    }
  }

  @media (max-width: 767px) {
    .cta__inner {
      padding-top: 3em;
    }

    .cta__image {
      height: 22em;
    }
  }

  @media (max-width: 479px) {
    .cta__image {
      height: 16em;
    }
  }

  /* ====================================================================
     TESTIMONIALS
     ==================================================================== */
  .testimonials {
    width: 100%;
    background-color: var(--color-bg-white);
  }

  .testimonials__inner {
    padding-block: 7.5em;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
