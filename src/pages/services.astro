---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Our Services | Home Improvement & Remodeling in Westminster, CO — Elite Property Innovations"
  description="Explore our full range of home improvement services: kitchen remodeling, bathroom remodeling, painting, carpentry, decks, fences, windows, roofing & more. Serving Westminster, Arvada, Broomfield & Denver."
>
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- ============================================================
         Hero Section
         ============================================================ -->
    <section class="services-hero">
      <div class="services-hero__gradient" aria-hidden="true"></div>
      <div class="services-hero__grid-overlay" aria-hidden="true"></div>
      <div class="services-hero__content container">
        <span class="section-label services-hero__eyebrow">Our Services</span>
        <h1 class="services-hero__heading">Home Improvement Services in Westminster&nbsp;&amp;&nbsp;Denver</h1>
        <p class="services-hero__subtext">From complete kitchen transformations to custom deck builds, Elite Property Innovations delivers the quality craftsmanship Westminster homeowners trust. Explore our full range of services below.</p>
        <div class="services-hero__ctas">
          <a href="/contact" class="btn btn--accent">Get a Free Estimate</a>
          <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         Services Grid Section — 10 Real Services
         ============================================================ -->
    <section class="services-grid-section" id="all-services">
      <div class="services-grid-section__inner container">
        <span class="section-label">What We Do</span>
        <h2 class="services-grid-section__heading">Comprehensive Home Improvement Solutions</h2>
        <p class="services-grid-section__subtext">
          Whether you need a single room refreshed or a whole-home renovation, our experienced team handles every phase — from planning to final walkthrough. All work is backed by our satisfaction guarantee.
        </p>

        <div class="services-grid">

          <!-- 1. Kitchen Remodeling -->
          <a href="/internal-services" class="service-card" id="service-kitchen">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/><path d="M3 9V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4"/><line x1="12" y1="13" x2="12" y2="17"/><line x1="8" y1="13" x2="8" y2="17"/><line x1="16" y1="13" x2="16" y2="17"/></svg>
            </div>
            <h3 class="service-card__title">Kitchen Remodeling</h3>
            <p class="service-card__desc">Custom cabinetry, countertops, backsplashes, and full layout redesigns. Modernize your kitchen with premium materials and expert installation.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 2. Bathroom Remodeling -->
          <a href="/internal-services" class="service-card" id="service-bathroom">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M4 12h16a1 1 0 0 1 1 1v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-3a1 1 0 0 1 1-1z"/><path d="M6 12V5a2 2 0 0 1 2-2h1"/><circle cx="9" cy="5" r="1"/></svg>
            </div>
            <h3 class="service-card__title">Bathroom Remodeling</h3>
            <p class="service-card__desc">Walk-in showers, tub-to-shower conversions, vanity upgrades, and complete bathroom renovations tailored to your style and budget.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 3. Interior & Exterior Painting -->
          <a href="/internal-services" class="service-card" id="service-painting">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M19 3H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/><path d="M12 11v4"/><path d="M10 15h4l-2 6-2-6z"/></svg>
            </div>
            <h3 class="service-card__title">Interior & Exterior Painting</h3>
            <p class="service-card__desc">Professional surface prep, premium paint application, and clean, crisp results. Transform any room or your home's curb appeal.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 4. Handyman Services -->
          <a href="/internal-services" class="service-card" id="service-handyman">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h3 class="service-card__title">Handyman Services</h3>
            <p class="service-card__desc">Fixture installs, shelving, minor repairs, and odd jobs. No project is too small — we'll get it done right the first time.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 5. Drywall Services -->
          <a href="/internal-services" class="service-card" id="service-drywall">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
            </div>
            <h3 class="service-card__title">Drywall Services</h3>
            <p class="service-card__desc">Drywall hanging, taping, mudding, texture matching, and seamless patching. Walls that look factory-smooth, guaranteed.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 6. Carpentry -->
          <a href="/internal-services" class="service-card" id="service-carpentry">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-6h6v6"/></svg>
            </div>
            <h3 class="service-card__title">Carpentry</h3>
            <p class="service-card__desc">Custom trim, crown molding, built-ins, shelving, and structural framing. Precision woodwork that elevates every room.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 7. Deck Construction & Repair -->
          <a href="/internal-services" class="service-card" id="service-deck">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M3 7h18"/><path d="M3 11h18"/><path d="M5 7v12"/><path d="M9 7v12"/><path d="M15 7v12"/><path d="M19 7v12"/><path d="M3 19h18"/></svg>
            </div>
            <h3 class="service-card__title">Deck Construction & Repair</h3>
            <p class="service-card__desc">New deck builds, board replacement, staining, sealing, and railing upgrades. Extend your outdoor living space with confidence.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 8. Fence Installation & Repair -->
          <a href="/internal-services" class="service-card" id="service-fence">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M4 4v16"/><path d="M12 4v16"/><path d="M20 4v16"/><path d="M4 8h8"/><path d="M12 8h8"/><path d="M4 14h8"/><path d="M12 14h8"/><path d="M2 4h4"/><path d="M10 4h4"/><path d="M18 4h4"/></svg>
            </div>
            <h3 class="service-card__title">Fence Installation & Repair</h3>
            <p class="service-card__desc">Wood, vinyl, and composite fencing. New installations, post replacements, and storm damage repair. Privacy and curb appeal in one.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 9. Window & Door Replacement -->
          <a href="/internal-services" class="service-card" id="service-windows">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
            </div>
            <h3 class="service-card__title">Window & Door Replacement</h3>
            <p class="service-card__desc">Energy-efficient window installs, entry door upgrades, and patio door replacements. Improve comfort and cut energy costs.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

          <!-- 10. Roofing Services -->
          <a href="/internal-services" class="service-card" id="service-roofing">
            <div class="service-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="service-card__icon"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v6"/></svg>
            </div>
            <h3 class="service-card__title">Roofing Services</h3>
            <p class="service-card__desc">Inspections, repairs, re-roofing, and gutter maintenance. Protect your home from Colorado's extreme weather year-round.</p>
            <span class="service-card__link">View service &rarr;</span>
          </a>

        </div>
      </div>
    </section>

    <!-- ============================================================
         Why EPI Section
         ============================================================ -->
    <section class="services-why">
      <div class="services-why__inner container">
        <span class="section-label">Why Elite Property Innovations</span>
        <h2 class="services-why__heading">What Sets Us Apart</h2>
        <p class="services-why__subtext">
          Not all contractors are created equal. Here's why Westminster homeowners choose us for their most important home projects.
        </p>
        <div class="services-why__grid">
          <div class="services-why__card">
            <div class="services-why__card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="services-why__card-title">25+ Years of Hands-On Experience</h3>
            <p class="services-why__card-desc">We've been transforming Colorado homes since before many competitors opened their doors. Experience means fewer mistakes and faster results.</p>
          </div>
          <div class="services-why__card">
            <div class="services-why__card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <h3 class="services-why__card-title">5-Star Google Rating</h3>
            <p class="services-why__card-desc">Our reviews speak for themselves. Real Westminster homeowners rating us 5 stars for quality, communication, and reliability.</p>
          </div>
          <div class="services-why__card">
            <div class="services-why__card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="services-why__card-title">Clear Communication, Always</h3>
            <p class="services-why__card-desc">You'll never wonder what's happening with your project. We provide detailed estimates, daily updates, and honest timelines.</p>
          </div>
          <div class="services-why__card">
            <div class="services-why__card-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="services-why__card-title">Locally Owned & Operated</h3>
            <p class="services-why__card-desc">We live and work in Westminster. Your home is in our neighborhood — and we treat it like our own.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         Testimonials Section — Real Google Reviews
         ============================================================ -->
    <section class="services-testimonials">
      <div class="services-testimonials__inner container">
        <span class="section-label">Client Reviews</span>
        <h2 class="services-testimonials__heading">What Westminster Homeowners Say</h2>
        <p class="services-testimonials__subtext">
          Real reviews from real customers. See why our neighbors trust us with their biggest home investments.
        </p>
        <div class="testimonials-grid">
          <div class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="testimonial-card__quote">
              &ldquo;Jacob and his team did an incredible job remodeling our home. We had a pretty large job that included a complete renovation of our bedroom, and they knocked it out of the park!&rdquo;
            </p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar-placeholder">C</div>
              <div>
                <span class="testimonial-card__name">Corie D.</span>
                <span class="testimonial-card__role">Home Remodel · Westminster</span>
              </div>
            </div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="testimonial-card__quote">
              &ldquo;The work they did on our property was absolutely amazing. They brought our vision to life. Professional, detailed, and just overall a great team to work with.&rdquo;
            </p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar-placeholder">G</div>
              <div>
                <span class="testimonial-card__name">Gabriella G.</span>
                <span class="testimonial-card__role">Renovation · Denver Metro</span>
              </div>
            </div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 out of 5 stars">★★★★★</div>
            <p class="testimonial-card__quote">
              &ldquo;We hired Elite Property Innovations for our renovation and couldn't be happier. They were communicative, thorough, and really cared about the quality of their work.&rdquo;
            </p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar-placeholder">A</div>
              <div>
                <span class="testimonial-card__name">Alyson A.</span>
                <span class="testimonial-card__role">Renovation · Westminster</span>
              </div>
            </div>
          </div>
        </div>
        <div class="services-testimonials__cta">
          <a href="https://www.google.com/maps/place/Elite+Property+Innovations" target="_blank" rel="noopener noreferrer" class="btn btn--outline">Read All Reviews on Google &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CTA Banner
         ============================================================ -->
    <section class="services-cta-banner">
      <div class="services-cta-banner__inner container">
        <h2 class="services-cta-banner__heading">Ready to Transform Your Home?</h2>
        <p class="services-cta-banner__text">Get a detailed, no-obligation estimate for your project. We respond within 60 seconds — even after hours.</p>
        <div class="services-cta-banner__actions">
          <a href="/contact" class="btn btn--accent">Get Your Free Estimate</a>
          <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<style>
  /* ==========================================================================
     Hero Section
     ========================================================================== */
  .services-hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    position: relative;
    overflow: hidden;
    padding: 10em 0 6em;
  }

  .services-hero__gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(0, 200, 232, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(168, 224, 0, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .services-hero__grid-overlay {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.02) 0px,
      rgba(255, 255, 255, 0.02) 1px,
      transparent 1px,
      transparent 60px
    );
    pointer-events: none;
  }

  .services-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .services-hero__eyebrow {
    margin-bottom: 1.5em;
  }

  .services-hero__heading {
    font-family: var(--font-heading);
    font-size: 3.5em;
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-text-white);
    max-width: 16em;
    margin-bottom: 0.5em;
  }

  .services-hero__subtext {
    font-size: 1.0625em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 38em;
    margin-bottom: 2em;
  }

  .services-hero__ctas {
    display: flex;
    gap: 1em;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ==========================================================================
     Services Grid Section
     ========================================================================== */
  .services-grid-section {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 6.25em;
  }

  .services-grid-section__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .services-grid-section__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-top: 0.75em;
    margin-bottom: 0.5em;
  }

  .services-grid-section__subtext {
    font-size: 1em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 44em;
    margin-bottom: 3em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25em;
    width: 100%;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2em 1.5em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    color: var(--color-primary);
  }

  .service-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .service-card__icon-wrap {
    width: 3.5em;
    height: 3.5em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 200, 232, 0.08);
    border-radius: var(--radius-md);
    margin-bottom: 1.25em;
  }

  .service-card__icon {
    width: 1.75em;
    height: 1.75em;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: 1em;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .service-card__desc {
    font-size: 0.8125em;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-bottom: 1.25em;
    flex-grow: 1;
  }

  .service-card__link {
    font-size: 0.8125em;
    font-weight: 600;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .service-card:hover .service-card__link {
    color: var(--color-accent);
  }

  /* ==========================================================================
     Why Section
     ========================================================================== */
  .services-why {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 6.25em;
  }

  .services-why__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .services-why__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-top: 0.75em;
    margin-bottom: 0.5em;
  }

  .services-why__subtext {
    font-size: 1em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 40em;
    margin-bottom: 3em;
  }

  .services-why__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25em;
    width: 100%;
  }

  .services-why__card {
    padding: 2em 1.5em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: left;
    transition: all var(--transition-base);
  }

  .services-why__card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
  }

  .services-why__card-icon {
    width: 3em;
    height: 3em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 200, 232, 0.08);
    border-radius: var(--radius-md);
    margin-bottom: 1.25em;
    color: var(--color-primary);
  }

  .services-why__card-title {
    font-family: var(--font-heading);
    font-size: 1.0625em;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .services-why__card-desc {
    font-size: 0.875em;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ==========================================================================
     Testimonials Section
     ========================================================================== */
  .services-testimonials {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 6.25em;
  }

  .services-testimonials__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .services-testimonials__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-top: 0.75em;
    margin-bottom: 0.5em;
  }

  .services-testimonials__subtext {
    font-size: 1em;
    line-height: 1.6;
