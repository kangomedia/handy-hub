---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Services | HandyHub" description="Expert handyman services for every need. Quality solutions from skilled professionals.">
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- ============================================================
         Hero Section
         ============================================================ -->
    <section class="services-hero">
      <div class="services-hero__pattern" aria-hidden="true"></div>
      <div class="services-hero__content container">
        <span class="section-label services-hero__eyebrow">HANDYHUB</span>
        <h1 class="services-hero__heading">Expert handyman services for every need</h1>
        <a href="/contact" class="btn btn--light">Contact us</a>
      </div>
      <div class="services-hero__image-wrap">
        <div class="services-hero__gradient" aria-hidden="true"></div>
        <img
          src="/assets/images/hero-services.jpg"
          alt="Professional handyman service in action"
          width="1440"
          height="600"
          class="services-hero__image"
          loading="eager"
        />
      </div>
      <div class="services-hero__partners container">
        <img src="/assets/images/logo-partner-1.png" alt="Partner logo" width="120" height="32" class="services-hero__partner-logo" loading="lazy" />
        <img src="/assets/images/logo-partner-2.png" alt="Partner logo" width="120" height="32" class="services-hero__partner-logo" loading="lazy" />
        <img src="/assets/images/logo-partner-3.png" alt="Partner logo" width="120" height="32" class="services-hero__partner-logo" loading="lazy" />
        <img src="/assets/images/logo-partner-4.png" alt="Partner logo" width="120" height="32" class="services-hero__partner-logo" loading="lazy" />
        <img src="/assets/images/logo-partner-5.png" alt="Partner logo" width="120" height="32" class="services-hero__partner-logo" loading="lazy" />
      </div>
    </section>

    <!-- ============================================================
         Services Section
         ============================================================ -->
    <section class="services-grid-section">
      <div class="services-grid-section__inner container">
        <span class="section-label">HANDYHUB</span>
        <h2 class="services-grid-section__heading">Quality Handyman Solutions</h2>
        <p class="services-grid-section__subtext">
          At QuickFix, we offer a comprehensive range of handyman services to keep your home in top condition. Whether it's a minor repair or a major project, our skilled team is here to help.
        </p>

        <div class="services-grid">
          <a href="/internal-services" class="service-card">
            <div class="service-card__icon-wrap">
              <img src="/assets/images/icon-home-repair.svg" alt="" role="presentation" width="24" height="24" class="service-card__icon" />
            </div>
            <h3 class="service-card__title">Home Repairs</h3>
            <p class="service-card__desc">From fixing leaky faucets to patching drywall, we handle all your home repair needs.</p>
            <span class="service-card__link">Learn more &rarr;</span>
          </a>

          <a href="/internal-services" class="service-card">
            <div class="service-card__icon-wrap">
              <img src="/assets/images/icon-furniture.svg" alt="" role="presentation" width="24" height="24" class="service-card__icon" />
            </div>
            <h3 class="service-card__title">Furniture Assembly</h3>
            <p class="service-card__desc">Professional assembly for all types of furniture, ensuring sturdy and precise results.</p>
            <span class="service-card__link">Learn more &rarr;</span>
          </a>

          <a href="/internal-services" class="service-card">
            <div class="service-card__icon-wrap">
              <img src="/assets/images/icon-painting.svg" alt="" role="presentation" width="24" height="24" class="service-card__icon" />
            </div>
            <h3 class="service-card__title">Painting</h3>
            <p class="service-card__desc">Interior and exterior painting services to refresh and beautify your home.</p>
            <span class="service-card__link">Learn more &rarr;</span>
          </a>

          <a href="/internal-services" class="service-card">
            <div class="service-card__icon-wrap">
              <img src="/assets/images/icon-plumbing.svg" alt="" role="presentation" width="24" height="24" class="service-card__icon" />
            </div>
            <h3 class="service-card__title">Plumbing</h3>
            <p class="service-card__desc">Expert plumbing solutions for leaks, clogs, installations, and more.</p>
            <span class="service-card__link">Learn more &rarr;</span>
          </a>

          <a href="/internal-services" class="service-card">
            <div class="service-card__icon-wrap">
              <img src="/assets/images/icon-electrical.svg" alt="" role="presentation" width="24" height="24" class="service-card__icon" />
            </div>
            <h3 class="service-card__title">Electrical Work</h3>
            <p class="service-card__desc">Safe and reliable electrical services, from outlet installation to lighting upgrades.</p>
            <span class="service-card__link">Learn more &rarr;</span>
          </a>

          <a href="/internal-services" class="service-card">
            <div class="service-card__icon-wrap">
              <img src="/assets/images/icon-carpentry.svg" alt="" role="presentation" width="24" height="24" class="service-card__icon" />
            </div>
            <h3 class="service-card__title">Carpentry</h3>
            <p class="service-card__desc">Custom carpentry work including shelving, trim, and cabinetry for your home.</p>
            <span class="service-card__link">Learn more &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         CTA Section
         ============================================================ -->
    <section class="services-cta">
      <div class="services-cta__pattern" aria-hidden="true"></div>
      <div class="services-cta__inner container">
        <div class="services-cta__content">
          <span class="section-label services-cta__eyebrow">HANDYHUB</span>
          <h2 class="services-cta__heading">Ready to get started?</h2>
          <p class="services-cta__text">
            Contact us today for a free estimate. Our team is ready to help with all your handyman needs.
          </p>
          <a href="/contact" class="btn btn--light">Contact us</a>
        </div>
        <div class="services-cta__image-wrap">
          <img
            src="/assets/images/cta-image.jpg"
            alt="Handyman working on a project"
            width="560"
            height="400"
            class="services-cta__image"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- ============================================================
         Testimonials Section
         ============================================================ -->
    <section class="services-testimonials">
      <div class="services-testimonials__inner container">
        <span class="section-label">HANDYHUB</span>
        <h2 class="services-testimonials__heading">What our clients say</h2>
        <p class="services-testimonials__subtext">
          Real feedback from homeowners who trust our handyman services.
        </p>

        <div class="testimonials-grid">
          <div class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="testimonial-card__quote">
              &ldquo;The team was professional, punctual, and did an amazing job on our kitchen renovation. Highly recommend!&rdquo;
            </p>
            <div class="testimonial-card__author">
              <img src="/assets/images/testimonial-avatar-1.jpg" alt="Sarah M." width="48" height="48" class="testimonial-card__avatar" loading="lazy" />
              <div>
                <span class="testimonial-card__name">Sarah M.</span>
                <span class="testimonial-card__role">Homeowner</span>
              </div>
            </div>
          </div>

          <div class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="testimonial-card__quote">
              &ldquo;Quick response time and excellent workmanship. They fixed our plumbing issues in no time.&rdquo;
            </p>
            <div class="testimonial-card__author">
              <img src="/assets/images/testimonial-avatar-2.jpg" alt="Michael R." width="48" height="48" class="testimonial-card__avatar" loading="lazy" />
              <div>
                <span class="testimonial-card__name">Michael R.</span>
                <span class="testimonial-card__role">Homeowner</span>
              </div>
            </div>
          </div>

          <div class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="testimonial-card__quote">
              &ldquo;Excellent attention to detail. Our bathroom remodel looks absolutely stunning. Will definitely use again.&rdquo;
            </p>
            <div class="testimonial-card__author">
              <img src="/assets/images/testimonial-avatar-3.jpg" alt="Emily T." width="48" height="48" class="testimonial-card__avatar" loading="lazy" />
              <div>
                <span class="testimonial-card__name">Emily T.</span>
                <span class="testimonial-card__role">Homeowner</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         Contact Section
         ============================================================ -->
    <section class="services-contact">
      <div class="services-contact__inner container">
        <div class="services-contact__text">
          <span class="section-label">HANDYHUB</span>
          <h2 class="services-contact__heading">Get in touch with us</h2>
          <p class="services-contact__desc">
            Have a question or need a quote? Fill out the form and our team will get back to you shortly.
          </p>
        </div>
        <form class="services-contact__form" action="#" method="post">
          <div class="services-contact__form-row">
            <div class="services-contact__field">
              <label for="contact-name" class="services-contact__label">Name</label>
              <input type="text" id="contact-name" name="name" class="services-contact__input" placeholder="Your name" required />
            </div>
            <div class="services-contact__field">
              <label for="contact-email" class="services-contact__label">Email</label>
              <input type="email" id="contact-email" name="email" class="services-contact__input" placeholder="Your email" required />
            </div>
          </div>
          <div class="services-contact__field">
            <label for="contact-message" class="services-contact__label">Message</label>
            <textarea id="contact-message" name="message" class="services-contact__textarea" placeholder="Your message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn">Send message</button>
        </form>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<style>
  /* ==========================================================================
     Hero Section
     ========================================================================== */
  .services-hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    height: 71.25em;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .services-hero__pattern {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.03) 0px,
      rgba(255, 255, 255, 0.03) 1px,
      transparent 1px,
      transparent 60px
    );
    pointer-events: none;
    z-index: 1;
  }

  .services-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 7.5em;
    padding-bottom: 3em;
  }

  .services-hero__eyebrow {
    color: var(--color-text-white-muted);
    margin-bottom: 1.5em;
  }

  .services-hero__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.2px;
    color: var(--color-text-white);
    max-width: 42.75em;
    margin-bottom: 1.5em;
  }

  .services-hero__image-wrap {
    position: absolute;
    bottom: 3.5em;
    left: 0;
    right: 0;
    height: 50%;
    z-index: 1;
  }

  .services-hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, var(--color-bg-dark), rgba(0, 0, 0, 0));
    z-index: 1;
  }

  .services-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .services-hero__partners {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3em;
    padding-block: 1.5em;
    width: 100%;
  }

  .services-hero__partner-logo {
    height: 2em;
    width: auto;
    opacity: 0.7;
    filter: brightness(0) invert(1);
  }

  /* ==========================================================================
     Services Grid Section
     ========================================================================== */
  .services-grid-section {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 7.5em;
  }

  .services-grid-section__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .services-grid-section__heading {
    font-family: var(--font-heading);
    font-size: 3em;
    font-weight: 400;
    line-height: 1.167;
    letter-spacing: -0.96px;
    color: var(--color-text-primary);
    margin-top: 1em;
    margin-bottom: 0.5em;
  }

  .services-grid-section__subtext {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 53em;
    margin-bottom: 3em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
    width: 100%;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    padding: 2em;
    background-color: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: box-shadow var(--transition-base);
  }

  .service-card:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .service-card__icon-wrap {
    width: 3em;
    height: 3em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    margin-bottom: 1.5em;
  }

  .service-card__icon {
    width: 1.5em;
    height: 1.5em;
  }

  .service-card__title {
    font-family: var(--font-heading);
    font-size: 1.25em;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.4px;
    color: var(--color-text-primary);
    margin-bottom: 0.5em;
  }

  .service-card__desc {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 400;
    line-height: 1.429;
    color: var(--color-text-secondary);
    margin-bottom: 1.5em;
    flex-grow: 1;
  }

  .service-card__link {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 500;
    line-height: 1.429;
    color: var(--color-text-primary);
  }

  /* ==========================================================================
     CTA Section
     ========================================================================== */
  .services-cta {
    width: 100%;
    background-color: var(--color-bg-dark);
    position: relative;
    overflow: hidden;
  }

  .services-cta__pattern {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.03) 0px,
      rgba(255, 255, 255, 0.03) 1px,
      transparent 1px,
      transparent 60px
    );
    pointer-events: none;
  }

  .services-cta__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 4em;
    padding-block: 6.25em;
  }

  .services-cta__content {
    flex: 1;
  }

  .services-cta__eyebrow {
    color: var(--color-text-white-muted);
    margin-bottom: 1.5em;
    display: block;
  }

  .services-cta__heading {
    font-family: var(--font-heading);
    font-size: 3em;
    font-weight: 400;
    line-height: 1.167;
    letter-spacing: -0.96px;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .services-cta__text {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-white-muted);
    margin-bottom: 2em;
    max-width: 32em;
  }

  .services-cta__image-wrap {
    flex-shrink: 0;
    width: 35em;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .services-cta__image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ==========================================================================
     Testimonials Section
     ========================================================================== */
  .services-testimonials {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 7.5em;
  }

  .services-testimonials__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .services-testimonials__heading {
    font-family: var(--font-heading);
    font-size: 3em;
    font-weight: 400;
    line-height: 1.167;
    letter-spacing: -0.96px;
    color: var(--color-text-primary);
    margin-top: 1em;
    margin-bottom: 0.5em;
  }

  .services-testimonials__subtext {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-bottom: 3em;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
    width: 100%;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    padding: 2em;
    background-color: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .testimonial-card__stars {
    color: #f5a623;
    font-size: 1.125em;
    margin-bottom: 1em;
    letter-spacing: 2px;
  }

  .testimonial-card__quote {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-bottom: 1.5em;
    flex-grow: 1;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 0.75em;
  }

  .testimonial-card__avatar {
    width: 3em;
    height: 3em;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonial-card__name {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.875em;
    font-weight: 500;
    line-height: 1.429;
    color: var(--color-text-primary);
  }

  .testimonial-card__role {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75em;
    font-weight: 400;
    line-height: 1.333;
    color: var(--color-text-secondary);
  }

  /* ==========================================================================
     Contact Section
     ========================================================================== */
  .services-contact {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 7.5em;
  }

  .services-contact__inner {
    display: flex;
    gap: 4em;
  }

  .services-contact__text {
    flex: 1;
  }

  .services-contact__text .section-label {
    color: var(--color-text-white-muted);
    display: block;
    margin-bottom: 1.5em;
  }

  .services-contact__heading {
    font-family: var(--font-heading);
    font-size: 3em;
    font-weight: 400;
    line-height: 1.167;
    letter-spacing: -0.96px;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .services-contact__desc {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text-white-muted);
    max-width: 28em;
  }

  .services-contact__form {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .services-contact__form-row {
    display: flex;
    gap: 1.5em;
  }

  .services-contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    flex: 1;
  }

  .services-contact__label {
    font-family: var(--font-body);
    font-size: 0.875em;
    font-weight: 500;
    line-height: 1.429;
    color: var(--color-text-white);
  }

  .services-contact__input,
  .services-contact__textarea {
    width: 100%;
    padding: 0.875em 1em;
    background-color: transparent;
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-md);
    color: var(--color-text-white);
    font-family: var(--font-body);
    font-size: 1em;
    line-height: 1.5;
  }

  .services-contact__input::placeholder,
  .services-contact__textarea::placeholder {
    color: var(--color-text-gray);
  }

  .services-contact__textarea {
    resize: vertical;
    min-height: 8em;
  }

  /* ==========================================================================
     Responsive — Tablet
     ========================================================================== */
  @media (max-width: 991px) {
    .services-hero {
      height: auto;
      min-height: 50em;
    }

    .services-hero__content {
      padding-top: 5em;
    }

    .services-hero__heading {
      font-size: 3em;
    }

    .services-hero__image-wrap {
      position: relative;
      bottom: auto;
      height: 25em;
    }

    .services-hero__partners {
      position: relative;
      left: auto;
      transform: none;
      flex-wrap: wrap;
      gap: 2em;
      padding-block: 1.5em;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .testimonials-grid .testimonial-card:last-child {
      grid-column: 1 / -1;
      max-width: 50%;
      margin-inline: auto;
    }

    .services-cta__inner {
      flex-direction: column;
      text-align: center;
    }

    .services-cta__content {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .services-cta__image-wrap {
      width: 100%;
      max-width: 35em;
    }

    .services-contact__inner {
      flex-direction: column;
    }
  }

  /* ==========================================================================
     Responsive — Mobile Landscape
     ========================================================================== */
  @media (max-width: 767px) {
    .services-hero__heading {
      font-size: 2.5em;
    }

    .services-hero__image-wrap {
      height: 18em;
    }

    .services-hero__partners {
      gap: 1.5em;
    }

    .services-hero__partner-logo {
      height: 1.5em;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .testimonials-grid .testimonial-card:last-child {
      max-width: 100%;
    }

    .services-cta__image-wrap {
      width: 100%;
    }

    .services-contact__form-row {
      flex-direction: column;
    }
  }

  /* ==========================================================================
     Responsive — Mobile Portrait
     ========================================================================== */
  @media (max-width: 479px) {
    .services-hero__heading {
      font-size: 2em;
