---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Interior & Exterior Painting in Westminster, CO — Elite Property Innovations"
  description="Professional painting services in Westminster & Denver. Interior rooms, exterior facades, cabinet painting, color consultation. 25+ years experience. Free estimates — (720) 299-1238."
>
  <Navbar variant="dark" />
  <main id="main-content">
    <section class="is-hero">
      <div class="is-hero__gradient" aria-hidden="true"></div>
      <div class="is-hero__grid-overlay" aria-hidden="true"></div>
      <div class="is-hero__content container">
        <div class="is-hero__text">
          <span class="section-label is-hero__eyebrow">Painting Services</span>
          <h1 class="is-hero__heading">Interior &amp; Exterior Painting in Westminster&nbsp;&amp;&nbsp;Denver</h1>
          <p class="is-hero__subtext">Transform your home with a fresh coat of paint. Our professional painters deliver flawless finishes on interior rooms, exterior facades, trim, decks, and cabinets.</p>
          <div class="is-hero__ctas">
            <a href="/contact" class="btn btn--accent">Get a Free Painting Quote</a>
            <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
          </div>
        </div>
        <div class="is-hero__stats">
          <div class="is-hero__stat"><span class="is-hero__stat-number">25+</span><span class="is-hero__stat-label">YEARS EXPERIENCE</span></div>
          <div class="is-hero__stat"><span class="is-hero__stat-number">1,000+</span><span class="is-hero__stat-label">PROJECTS COMPLETED</span></div>
          <div class="is-hero__stat"><span class="is-hero__stat-number">5.0★</span><span class="is-hero__stat-label">GOOGLE RATING</span></div>
          <div class="is-hero__stat"><span class="is-hero__stat-number">100%</span><span class="is-hero__stat-label">SATISFACTION GUARANTEE</span></div>
        </div>
      </div>
    </section>
    <section class="is-benefits">
      <div class="is-benefits__inner container">
        <span class="section-label">Why Choose Us for Painting</span>
        <h2 class="is-benefits__heading">The EPI Painting Advantage</h2>
        <p class="is-benefits__subtext">A quality paint job isn't just about color — it's about preparation, precision, and using the right products for Colorado's climate.</p>
        <div class="is-benefits__grid">
          <div class="is-benefit-card"><div class="is-benefit-card__icon-wrap"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div><h3 class="is-benefit-card__title">Proper Prep Work</h3><p class="is-benefit-card__desc">Sanding, priming, caulking, and patching before any paint goes on. This is why our finishes last years longer than the competition.</p></div>
          <div class="is-benefit-card"><div class="is-benefit-card__icon-wrap"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div><h3 class="is-benefit-card__title">Premium Paints</h3><p class="is-benefit-card__desc">We use Sherwin-Williams and Benjamin Moore products — low-VOC, durable, and designed to withstand Colorado's UV exposure and temperature swings.</p></div>
          <div class="is-benefit-card"><div class="is-benefit-card__icon-wrap"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><h3 class="is-benefit-card__title">Clean & Efficient</h3><p class="is-benefit-card__desc">Drop cloths, tape, and careful masking protect your home. We clean up daily so you're never living in a construction zone.</p></div>
          <div class="is-benefit-card"><div class="is-benefit-card__icon-wrap"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div><h3 class="is-benefit-card__title">Color Consultation</h3><p class="is-benefit-card__desc">Not sure what color to choose? We offer expert color consultation to help you find the perfect palette for your home's style and neighborhood.</p></div>
        </div>
      </div>
    </section>
    <section class="is-feature-image"><div class="is-feature-image__inner container"><img src="/assets/images/portfolio-painting.jpg" alt="Professional interior painting — clean lines and flawless finish in Westminster, CO" width="1200" height="500" loading="lazy" class="is-feature-image__img" /></div></section>
    <section class="is-included">
      <div class="is-included__inner container">
        <div class="is-included__left">
          <span class="section-label">What's Included</span>
          <h2 class="is-included__heading">Our Painting Services</h2>
          <p class="is-included__desc">From a single accent wall to a whole-house exterior repaint, we handle projects of every size with the same attention to detail.</p>
          <div class="is-included__cta"><a href="/contact" class="btn btn--accent">Discuss Your Painting Project</a></div>
        </div>
        <div class="is-included__right">
          <div class="is-accordion" data-accordion>
            <div class="is-accordion__item is-accordion__item--active" data-accordion-item>
              <button class="is-accordion__header" type="button" aria-expanded="true"><div class="is-accordion__header-left"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="is-accordion__icon-svg"><path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/><path d="M3 9V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4"/></svg><span class="is-accordion__title">INTERIOR PAINTING</span></div><span class="is-accordion__toggle" aria-hidden="true"><svg width="14" height="2" viewBox="0 0 14 2" fill="none"><rect width="14" height="2" fill="currentColor"/></svg></span></button>
              <div class="is-accordion__body"><p class="is-accordion__text">Walls, ceilings, trim, doors, and closets. We handle every room in your home with precision cutting-in, smooth rolling, and zero mess.</p></div>
            </div>
            <div class="is-accordion__item" data-accordion-item>
              <button class="is-accordion__header" type="button" aria-expanded="false"><div class="is-accordion__header-left"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="is-accordion__icon-svg"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/></svg><span class="is-accordion__title">EXTERIOR PAINTING</span></div><span class="is-accordion__toggle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg></span></button>
              <div class="is-accordion__body" hidden><p class="is-accordion__text">Siding, fascia, soffits, shutters, front doors, and garage doors. We power wash, scrape, prime, and apply weatherproof finishes built for Colorado.</p></div>
            </div>
            <div class="is-accordion__item" data-accordion-item>
              <button class="is-accordion__header" type="button" aria-expanded="false"><div class="is-accordion__header-left"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="is-accordion__icon-svg"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg><span class="is-accordion__title">CABINET & SPECIALTY PAINTING</span></div><span class="is-accordion__toggle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg></span></button>
              <div class="is-accordion__body" hidden><p class="is-accordion__text">Kitchen cabinet painting, bathroom vanities, built-in shelving, and accent features. Spray-finished for a factory-smooth look at a fraction of replacement cost.</p></div>
            </div>
            <div class="is-accordion__item" data-accordion-item>
              <button class="is-accordion__header" type="button" aria-expanded="false"><div class="is-accordion__header-left"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="is-accordion__icon-svg"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-6h6v6"/></svg><span class="is-accordion__title">DECK & FENCE STAINING</span></div><span class="is-accordion__toggle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg></span></button>
              <div class="is-accordion__body" hidden><p class="is-accordion__text">Restore and protect your outdoor wood with professional staining and sealing. We clean, sand, and apply UV-resistant stains for lasting beauty.</p></div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section class="is-cta-banner"><div class="is-cta-banner__inner container"><h2 class="is-cta-banner__heading">Ready for a Fresh Look?</h2><p class="is-cta-banner__text">Get a detailed, no-obligation estimate for your painting project. We'll walk you through colors, timelines, and pricing — no pressure.</p><div class="is-cta-banner__actions"><a href="/contact" class="btn btn--accent">Get Your Free Painting Estimate</a><a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a></div></div></section>
    <Footer />
  </main>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => { const accordion = document.querySelector('[data-accordion]'); if (!accordion) return; const items = accordion.querySelectorAll('[data-accordion-item]'); items.forEach((item) => { const header = item.querySelector('.is-accordion__header'); const body = item.querySelector('.is-accordion__body'); const toggle = item.querySelector('.is-accordion__toggle'); header.addEventListener('click', () => { const isOpen = item.classList.contains('is-accordion__item--active'); items.forEach((o) => { o.classList.remove('is-accordion__item--active'); o.querySelector('.is-accordion__body').hidden = true; o.querySelector('.is-accordion__header').setAttribute('aria-expanded','false'); o.querySelector('.is-accordion__toggle').innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect y="6" width="14" height="2" fill="currentColor"/><rect x="6" width="2" height="14" fill="currentColor"/></svg>'; }); if (!isOpen) { item.classList.add('is-accordion__item--active'); body.hidden = false; header.setAttribute('aria-expanded','true'); toggle.innerHTML = '<svg width="14" height="2" viewBox="0 0 14 2" fill="none"><rect width="14" height="2" fill="currentColor"/></svg>'; } }); }); });
</script>

<style>
  .is-hero { width: 100%; background-color: var(--color-bg-dark); background-image: url('/assets/images/hero-home.jpg'); background-size: cover; background-position: center; position: relative; overflow: hidden; padding: 10em 0 6em; }
  .is-hero__gradient { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,15,20,0.8) 0%, rgba(10,15,20,0.92) 100%), radial-gradient(ellipse at 30% 20%, rgba(0,200,232,0.08) 0%, transparent 60%), radial-gradient(ellipse at 70% 80%, rgba(168,224,0,0.05) 0%, transparent 50%); pointer-events: none; }
  .is-hero__grid-overlay { position: absolute; inset: 0; background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px, transparent 1px, transparent 60px); pointer-events: none; }
  .is-hero__content { position: relative; z-index: 2; } .is-hero__text { display: flex; flex-direction: column; align-items: flex-start; max-width: 36em; } .is-hero__eyebrow { margin-bottom: 1.5em; }
  .is-hero__heading { font-family: var(--font-heading); font-size: 3.5em; font-weight: 800; line-height: 1.1; color: var(--color-text-white); margin-bottom: 0.4em; }
  .is-hero__subtext { font-size: 1.0625em; line-height: 1.6; color: var(--color-text-secondary); margin-bottom: 2em; }
  .is-hero__ctas { display: flex; gap: 1em; flex-wrap: wrap; }
  .is-hero__stats { display: flex; gap: 3em; margin-top: 3em; padding-top: 2em; border-top: 1px solid var(--color-border); }
  .is-hero__stat { display: flex; flex-direction: column; gap: 0.25em; } .is-hero__stat-number { font-family: var(--font-heading); font-size: 2em; font-weight: 800; line-height: 1.2; color: var(--color-text-white); } .is-hero__stat-label { font-size: 0.6875em; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--color-text-secondary); }
  .is-benefits { width: 100%; background-color: var(--color-bg-white); padding-block: 6.25em; } .is-benefits__inner { display: flex; flex-direction: column; align-items: center; text-align: center; } .is-benefits__heading { font-family: var(--font-heading); font-size: 2.75em; font-weight: 800; line-height: 1.15; color: var(--color-text-white); margin-top: 0.75em; margin-bottom: 0.5em; } .is-benefits__subtext { font-size: 1em; line-height: 1.6; color: var(--color-text-secondary); max-width: 40em; margin-bottom: 3em; } .is-benefits__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25em; width: 100%; max-width: 60em; }
  .is-benefit-card { display: flex; flex-direction: column; align-items: flex-start; text-align: left; padding: 2em; background-color: var(--color-bg-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); transition: all var(--transition-base); } .is-benefit-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-card-hover); } .is-benefit-card__icon-wrap { width: 3em; height: 3em; display: flex; align-items: center; justify-content: center; background: rgba(0,200,232,0.08); border-radius: var(--radius-md); margin-bottom: 1.25em; color: var(--color-primary); } .is-benefit-card__title { font-family: var(--font-heading); font-size: 1.125em; font-weight: 700; line-height: 1.3; color: var(--color-text-white); margin-bottom: 0.5em; } .is-benefit-card__desc { font-size: 0.875em; line-height: 1.6; color: var(--color-text-secondary); }
  .is-feature-image { width: 100%; background-color: var(--color-bg-dark); padding-block: 3em 6em; } .is-feature-image__inner { max-width: var(--max-width); margin: 0 auto; } .is-feature-image__img { width: 100%; height: 24em; object-fit: cover; border-radius: var(--radius-lg); border: 1px solid var(--color-border); display: block; }
  .is-included { width: 100%; background-color: var(--color-bg-dark); padding-block: 6.25em; } .is-included__inner { display: flex; gap: 3.75em; } .is-included__left { flex: 1; } .is-included__left .section-label { display: block; margin-bottom: 0.75em; } .is-included__heading { font-family: var(--font-heading); font-size: 2.75em; font-weight: 800; line-height: 1.15; color: var(--color-text-white); margin-bottom: 0.5em; } .is-included__desc { font-size: 1em; line-height: 1.6; color: var(--color-text-secondary); max-width: 28em; margin-bottom: 2em; } .is-included__right { flex: 1; }
  .is-accordion { display: flex; flex-direction: column; gap: 0.75em; } .is-accordion__item { border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; background-color: var(--color-bg-surface); transition: border-color var(--transition-base); } .is-accordion__item--active { border-color: var(--color-primary); } .is-accordion__header { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 1.25em; background: none; border: none; cursor: pointer; font: inherit; color: inherit; } .is-accordion__header-left { display: flex; align-items: center; gap: 0.75em; } .is-accordion__icon-svg { width: 1.25em; height: 1.25em; flex-shrink: 0; color: var(--color-primary); } .is-accordion__title { font-family: var(--font-heading); font-size: 0.8125em; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--color-text-white); } .is-accordion__toggle { display: flex; align-items: center; justify-content: center; width: 2.5em; height: 2.5em; background-color: var(--color-bg-dark); border-radius: var(--radius-md); flex-shrink: 0; color: var(--color-primary); } .is-accordion__body { padding: 0 1.25em 1.25em; } .is-accordion__text { font-size: 0.875em; line-height: 1.6; color: var(--color-text-secondary); padding-left: 2.25em; }
  .is-cta-banner { width: 100%; background-color: var(--color-bg-dark); background-image: url('/assets/images/hero-cta.jpg'); background-size: cover; background-position: center; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding-block: 5em; position: relative; } .is-cta-banner::before { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,15,20,0.88) 0%, rgba(10,15,20,0.94) 100%); pointer-events: none; } .is-cta-banner__inner { text-align: center; position: relative; z-index: 1; } .is-cta-banner__heading { font-family: var(--font-heading); font-size: 2.5em; font-weight: 800; color: var(--color-text-white); margin-bottom: 0.5em; } .is-cta-banner__text { font-size: 1.0625em; line-height: 1.6; color: var(--color-text-secondary); max-width: 36em; margin-inline: auto; margin-bottom: 2em; } .is-cta-banner__actions { display: flex; gap: 1em; justify-content: center; flex-wrap: wrap; }
  @media (max-width: 991px) { .is-hero__heading { font-size: 2.75em; } .is-hero__stats { flex-wrap: wrap; gap: 2em; } .is-benefits__grid { max-width: 100%; } .is-included__inner { flex-direction: column; gap: 2.5em; } .is-included__left { text-align: center; } .is-included__desc { max-width: 100%; } .is-included__cta { display: flex; justify-content: center; } }
  @media (max-width: 767px) { .is-hero { padding: 8em 0 4em; } .is-hero__heading { font-size: 2.25em; } .is-hero__stats { gap: 1.5em; } .is-hero__stat-number { font-size: 1.75em; } .is-benefits__grid { grid-template-columns: 1fr; } .is-accordion__title { font-size: 0.75em; letter-spacing: 1.5px; } .is-accordion__toggle { width: 2.25em; height: 2.25em; } .is-cta-banner__heading { font-size: 2em; } }
  @media (max-width: 479px) { .is-hero__heading { font-size: 1.875em; } .is-hero__stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5em; } .is-hero__stat-number { font-size: 1.5em; } .is-hero__ctas, .is-cta-banner__actions { flex-direction: column; width: 100%; } .is-hero__ctas .btn, .is-cta-banner__actions .btn { width: 100%; } .is-cta-banner__heading { font-size: 1.75em; } }
</style>
