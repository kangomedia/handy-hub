---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About Us | Elite Property Innovations — Westminster's Trusted Contractor"
  description="Learn about Elite Property Innovations — 25+ years of quality home improvement in Westminster, CO. Meet Jacob, our founder, and discover our commitment to integrity and craftsmanship."
>
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- ========== HERO ========== -->
    <section class="about-hero">
      <div class="about-hero__gradient" aria-hidden="true"></div>
      <div class="about-hero__grid-overlay" aria-hidden="true"></div>
      <div class="about-hero__inner container">
        <div class="about-hero__content">
          <span class="section-label about-hero__eyebrow">About Us</span>
          <h1 class="about-hero__heading">Building Trust, One Colorado Home at a&nbsp;Time</h1>
          <p class="about-hero__text">
            Elite Property Innovations was founded on a simple belief: homeowners deserve a contractor who shows up when they say they will, communicates openly, and takes pride in every detail. For over 25 years, we've been proving that great craftsmanship and genuine care go hand in hand.
          </p>
          <div class="about-hero__ctas">
            <a href="/contact" class="btn btn--accent">Get a Free Estimate</a>
            <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
          </div>
          <div class="about-hero__stats">
            <div class="about-hero__stat">
              <span class="about-hero__stat-number">25+</span>
              <span class="about-hero__stat-label">YEARS EXPERIENCE</span>
            </div>
            <div class="about-hero__stat">
              <span class="about-hero__stat-number">1,000+</span>
              <span class="about-hero__stat-label">PROJECTS COMPLETED</span>
            </div>
            <div class="about-hero__stat">
              <span class="about-hero__stat-number">5.0★</span>
              <span class="about-hero__stat-label">GOOGLE RATING</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== OUR STORY ========== -->
    <section class="our-story">
      <div class="our-story__inner container">
        <div class="our-story__image-col">
          <img src="/assets/images/about-story.jpg" alt="Elite Property Innovations team at work on a Westminster home improvement project" width="600" height="500" loading="lazy" class="our-story__image" />
        </div>
        <div class="our-story__content">
          <span class="section-label">Our Story</span>
          <h2 class="our-story__heading">Rooted in Westminster, Built on Integrity</h2>
          <p class="our-story__text">
            Jacob founded Elite Property Innovations with one goal: to bring the kind of craftsmanship and reliability to Westminster that homeowners actually deserve. After years of seeing contractors cut corners, overbill, and ghost their clients, he decided to build something different — a company where communication is constant, timelines are real, and every project meets the standard he'd set for his own home.
          </p>
          <p class="our-story__text">
            What started as a one-man operation has grown into a trusted team serving Westminster, Arvada, Broomfield, Thornton, Northglenn, and the greater Denver metro. But the values haven't changed: show up, do excellent work, and treat every homeowner like a neighbor — because they are.
          </p>
          <div class="our-story__items">
            <div class="our-story__item">
              <div class="our-story__item-icon-wrap">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div>
                <h3 class="our-story__item-title">Our Mission</h3>
                <p class="our-story__item-text">Deliver home improvements that exceed expectations — on time, on budget, and with the kind of attention to detail that makes you proud to show off your home.</p>
              </div>
            </div>
            <div class="our-story__item">
              <div class="our-story__item-icon-wrap">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h3 class="our-story__item-title">Our Values</h3>
                <p class="our-story__item-text">Honesty, transparency, and accountability. We give detailed estimates upfront, communicate every step of the way, and never charge for work we didn't complete to your satisfaction.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== WHY CHOOSE US ========== -->
    <section class="why-choose">
      <div class="why-choose__inner container">
        <div class="why-choose__header">
          <span class="section-label">Why Choose Us</span>
          <h2 class="why-choose__heading">The EPI Difference</h2>
          <p class="why-choose__subtext">
            We're not just another contractor. We're the team Westminster homeowners call when they want the job done right — and done with respect.
          </p>
        </div>
        <div class="why-choose__grid">
          <div class="why-choose__card">
            <div class="why-choose__card-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 class="why-choose__card-title">We Show Up When We Say We Will</h3>
            <p class="why-choose__card-desc">Punctuality isn't a bonus — it's the baseline. We respect your time because we know your schedule matters.</p>
          </div>
          <div class="why-choose__card">
            <div class="why-choose__card-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 class="why-choose__card-title">Clear Communication, Always</h3>
            <p class="why-choose__card-desc">Daily updates, detailed estimates, and honest timelines. You'll never have to chase us for an answer.</p>
          </div>
          <div class="why-choose__card">
            <div class="why-choose__card-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h3 class="why-choose__card-title">Quality Over Speed</h3>
            <p class="why-choose__card-desc">We'd rather take an extra day to get it perfect than rush and leave you with "good enough." Your home deserves better.</p>
          </div>
          <div class="why-choose__card">
            <div class="why-choose__card-icon-wrap">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="why-choose__card-title">Colorado Homes, Colorado Expertise</h3>
            <p class="why-choose__card-desc">We know the Denver climate, local building codes, and what materials hold up against Colorado weather.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CTA SECTION ========== -->
    <section class="about-cta">
      <div class="about-cta__inner container">
        <h2 class="about-cta__heading">Let's Talk About Your Project</h2>
        <p class="about-cta__text">
          Whether you're planning a full remodel or just need a quick fix, we'd love to hear about it. Free estimates, honest advice, and zero pressure.
        </p>
        <div class="about-cta__actions">
          <a href="/contact" class="btn btn--accent">Get Your Free Estimate</a>
          <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* ========== ABOUT HERO ========== */
  .about-hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    background-image: url('/assets/images/hero-about.jpg');
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    padding: 10em 0 6em;
  }

  .about-hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10, 15, 20, 0.8) 0%, rgba(10, 15, 20, 0.9) 100%),
                radial-gradient(ellipse at 30% 20%, rgba(0, 200, 232, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(168, 224, 0, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .about-hero__grid-overlay {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.02) 0px,
      rgba(255, 255, 255, 0.02) 1px,
      transparent 1px,
      transparent 60px
    );
    pointer-events: none;
  }

  .about-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
  }

  .about-hero__content {
    max-width: 42em;
    text-align: center;
  }

  .about-hero__eyebrow {
    display: block;
    margin-bottom: 1.5em;
  }

  .about-hero__heading {
    font-family: var(--font-heading);
    font-size: 3.5em;
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .about-hero__text {
    font-size: 1.0625em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 2em;
  }

  .about-hero__ctas {
    display: flex;
    gap: 1em;
    justify-content: center;
    flex-wrap: wrap;
  }

  .about-hero__stats {
    display: flex;
    gap: 3em;
    justify-content: center;
    margin-top: 3em;
    padding-top: 2em;
    border-top: 1px solid var(--color-border);
  }

  .about-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
    text-align: center;
  }

  .about-hero__stat-number {
    font-family: var(--font-heading);
    font-size: 2em;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text-white);
  }

  .about-hero__stat-label {
    font-size: 0.6875em;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  /* ========== OUR STORY ========== */
  .our-story {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 6.25em;
  }

  .our-story__inner {
    display: flex;
    gap: 3.75em;
    align-items: flex-start;
  }

  .our-story__image-col {
    flex: 1;
    min-width: 0;
  }

  .our-story__image {
    width: 100%;
    height: 32em;
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    display: block;
  }

  .our-story__content {
    flex: 1;
    min-width: 0;
  }

  .our-story__content .section-label {
    display: block;
    margin-bottom: 1em;
  }

  .our-story__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .our-story__text {
    font-size: 0.9375em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1.5em;
  }

  .our-story__items {
    display: flex;
    flex-direction: column;
    gap: 1.5em;
    margin-top: 1em;
  }

  .our-story__item {
    display: flex;
    gap: 1em;
    align-items: flex-start;
  }

  .our-story__item-icon-wrap {
    width: 2.75em;
    height: 2.75em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 200, 232, 0.08);
    border-radius: var(--radius-md);
    flex-shrink: 0;
    color: var(--color-primary);
    margin-top: 0.125em;
  }

  .our-story__item-title {
    font-family: var(--font-heading);
    font-size: 1.125em;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-white);
    margin-bottom: 0.25em;
  }

  .our-story__item-text {
    font-size: 0.875em;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ========== WHY CHOOSE US ========== */
  .why-choose {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 6.25em;
  }

  .why-choose__inner {
    display: flex;
    flex-direction: column;
  }

  .why-choose__header {
    margin-bottom: 3em;
    text-align: center;
  }

  .why-choose__header .section-label {
    display: block;
    margin-bottom: 0.75em;
  }

  .why-choose__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .why-choose__subtext {
    font-size: 1em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 36em;
    margin-inline: auto;
  }

  .why-choose__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25em;
  }

  .why-choose__card {
    padding: 2em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
  }

  .why-choose__card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
  }

  .why-choose__card-icon-wrap {
    width: 2.75em;
    height: 2.75em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 200, 232, 0.08);
    border-radius: var(--radius-md);
    margin-bottom: 1.25em;
    color: var(--color-primary);
  }

  .why-choose__card-title {
    font-family: var(--font-heading);
    font-size: 1.125em;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .why-choose__card-desc {
    font-size: 0.875em;
    line-height: 1.6;
    color: var(--color-text-secondary);
  }

  /* ========== CTA SECTION ========== */
  .about-cta {
    width: 100%;
    background-color: var(--color-bg-dark);
    background-image: url('/assets/images/hero-cta.jpg');
    background-size: cover;
    background-position: center;
    border-top: 1px solid var(--color-border);
    padding-block: 5em;
    position: relative;
  }

  .about-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10, 15, 20, 0.88) 0%, rgba(10, 15, 20, 0.94) 100%);
    pointer-events: none;
  }

  .about-cta__inner {
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .about-cta__heading {
    font-family: var(--font-heading);
    font-size: 2.5em;
    font-weight: 800;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .about-cta__text {
    font-size: 1.0625em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 36em;
    margin-inline: auto;
    margin-bottom: 2em;
  }

  .about-cta__actions {
    display: flex;
    gap: 1em;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ========== RESPONSIVE ========== */

  /* Tablet */
  @media (max-width: 991px) {
    .about-hero__heading {
      font-size: 2.75em;
    }

    .our-story__inner {
      flex-direction: column;
    }

    .our-story__image {
      height: 22em;
    }

    .why-choose__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .about-hero {
      padding: 8em 0 4em;
    }

    .about-hero__heading {
      font-size: 2.25em;
    }

    .about-hero__stats {
      flex-wrap: wrap;
      gap: 2em;
    }

    .our-story__heading,
    .why-choose__heading {
      font-size: 2.25em;
    }

    .about-cta__heading {
      font-size: 2em;
    }
  }

  /* Mobile portrait */
  @media (max-width: 479px) {
    .about-hero__heading {
      font-size: 1.875em;
    }

    .about-hero__stats {
      flex-direction: column;
      gap: 1.5em;
    }

    .about-hero__ctas,
    .about-cta__actions {
      flex-direction: column;
    }

    .about-hero__ctas .btn,
    .about-cta__actions .btn {
      width: 100%;
    }

    .our-story__heading,
    .why-choose__heading {
      font-size: 1.875em;
    }

    .about-cta__heading {
      font-size: 1.75em;
    }
  }
</style>
