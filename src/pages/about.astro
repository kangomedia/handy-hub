---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About Us | HandyHub" description="Learn about HandyHub — 10 years of quality handyman services in New York. Meet our experienced team and discover our story.">
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- ========== HERO ========== -->
    <section class="about-hero">
      <div class="about-hero__lines" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span>
      </div>
      <div class="about-hero__image-wrapper">
        <img
          src="/assets/images/hero-about.jpg"
          alt="Handyman at work on a residential project"
          width="652"
          height="864"
          class="about-hero__image"
        />
      </div>
      <div class="about-hero__inner container">
        <div class="about-hero__content">
          <span class="section-label about-hero__eyebrow">HANDYHUB</span>
          <h1 class="about-hero__heading">Build relationships, one home at a time</h1>
          <p class="about-hero__text">
            At QuickFix, we believe that every home deserves the best care. Founded on a commitment to quality workmanship and exceptional customer service, we have been proudly serving the New York community for 10 years.
          </p>
          <a href="/contact" class="btn btn--light">Contact us</a>
          <div class="about-hero__stats">
            <div class="about-hero__stat">
              <span class="about-hero__stat-number">10y</span>
              <span class="about-hero__stat-label">EXPEREINCES</span>
            </div>
            <div class="about-hero__stat">
              <span class="about-hero__stat-number">100+</span>
              <span class="about-hero__stat-label">TEAM MEMBERS</span>
            </div>
            <div class="about-hero__stat">
              <span class="about-hero__stat-number">1k</span>
              <span class="about-hero__stat-label">PROJECTS</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== WHY CHOOSE US ========== -->
    <section class="why-choose">
      <div class="why-choose__inner container">
        <div class="why-choose__header">
          <span class="section-label">HANDYHUB</span>
          <h2 class="why-choose__heading">Why choose us?</h2>
          <p class="why-choose__subtext">
            We are dedicated to delivering top-quality craftsmanship and exceptional service on every project.
          </p>
        </div>
        <div class="why-choose__grid">
          <div class="why-choose__card why-choose__card--open">
            <div class="why-choose__card-header">
              <div class="why-choose__card-icon-title">
                <img src="/assets/images/icon-discount.svg" alt="" role="presentation" width="24" height="24" class="why-choose__card-icon" />
                <h3 class="why-choose__card-title">Transparent Pricing</h3>
              </div>
              <button class="why-choose__card-toggle" aria-label="Toggle Transparent Pricing details" aria-expanded="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/></svg>
              </button>
            </div>
            <div class="why-choose__card-body">
              <p>No hidden fees, no surprises—just clear, honest pricing for every job. We provide detailed estimates upfront so you know exactly what to expect.</p>
            </div>
          </div>
          <div class="why-choose__card">
            <div class="why-choose__card-header">
              <div class="why-choose__card-icon-title">
                <img src="/assets/images/icon-home-repair.svg" alt="" role="presentation" width="24" height="24" class="why-choose__card-icon" />
                <h3 class="why-choose__card-title">Experienced and Skilled Team</h3>
              </div>
              <button class="why-choose__card-toggle" aria-label="Toggle Experienced and Skilled Team details" aria-expanded="false">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2"/></svg>
              </button>
            </div>
            <div class="why-choose__card-body" hidden>
              <p>Our team of highly trained professionals brings years of experience to every project, ensuring quality results you can count on.</p>
            </div>
          </div>
          <div class="why-choose__card">
            <div class="why-choose__card-header">
              <div class="why-choose__card-icon-title">
                <img src="/assets/images/icon-trusted.svg" alt="" role="presentation" width="24" height="24" class="why-choose__card-icon" />
                <h3 class="why-choose__card-title">Reliable and Trustworthy</h3>
              </div>
              <button class="why-choose__card-toggle" aria-label="Toggle Reliable and Trustworthy details" aria-expanded="false">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2"/></svg>
              </button>
            </div>
            <div class="why-choose__card-body" hidden>
              <p>We know how important it is to trust the people working in your home. Our team is fully vetted and committed to your safety and satisfaction.</p>
            </div>
          </div>
          <div class="why-choose__card">
            <div class="why-choose__card-header">
              <div class="why-choose__card-icon-title">
                <img src="/assets/images/icon-people-toolbox.svg" alt="" role="presentation" width="24" height="24" class="why-choose__card-icon" />
                <h3 class="why-choose__card-title">Customer-Focused Approach</h3>
              </div>
              <button class="why-choose__card-toggle" aria-label="Toggle Customer-Focused Approach details" aria-expanded="false">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2"/></svg>
              </button>
            </div>
            <div class="why-choose__card-body" hidden>
              <p>Your needs and satisfaction are at the center of everything we do. We listen, adapt, and deliver solutions tailored to your home.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== OUR STORY ========== -->
    <section class="our-story">
      <div class="our-story__inner container">
        <div class="our-story__image-col">
          <img
            src="/assets/images/about-story.jpg"
            alt="Handyman team collaborating on a home improvement project"
            width="552"
            height="637"
            class="our-story__image"
            loading="lazy"
          />
        </div>
        <div class="our-story__content">
          <span class="section-label">HANDYHUB</span>
          <h2 class="our-story__heading">Our story</h2>
          <p class="our-story__text">
            Founded in 2014, HandyHub started with a simple idea: every homeowner deserves access to reliable, high-quality handyman services. What began as a small team of dedicated professionals has grown into a trusted name in the New York community.
          </p>
          <div class="our-story__items">
            <div class="our-story__item">
              <img src="/assets/images/icon-discount.svg" alt="" role="presentation" width="24" height="24" class="our-story__item-icon" />
              <div>
                <h3 class="our-story__item-title">Our Mission</h3>
                <p class="our-story__item-text">Our mission is simple: to provide top-quality handyman services that make your home a better place to live.</p>
              </div>
            </div>
            <div class="our-story__item">
              <img src="/assets/images/icon-discount.svg" alt="" role="presentation" width="24" height="24" class="our-story__item-icon" />
              <div>
                <h3 class="our-story__item-title">Our Values</h3>
                <p class="our-story__item-text">Honesty and transparency guide everything we do. We believe in fair pricing, open communication, and delivering on our promises.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== TEAMS ========== -->
    <section class="teams">
      <div class="teams__inner container">
        <div class="teams__header">
          <span class="section-label">HANDYHUB</span>
          <h2 class="teams__heading">Meet our team</h2>
          <p class="teams__subtext">
            Our skilled professionals are dedicated to delivering quality workmanship on every project.
          </p>
        </div>
        <div class="teams__grid">
          <div class="teams__card">
            <img src="/assets/images/team-member-1.jpg" alt="James Vile, Founder" width="340" height="400" class="teams__card-image" loading="lazy" />
            <h3 class="teams__card-name">James Vile</h3>
            <p class="teams__card-role">Founder</p>
          </div>
          <div class="teams__card">
            <img src="/assets/images/team-member-2.jpg" alt="Sarah Johnson, Lead Technician" width="340" height="400" class="teams__card-image" loading="lazy" />
            <h3 class="teams__card-name">Sarah Johnson</h3>
            <p class="teams__card-role">Lead Technician</p>
          </div>
          <div class="teams__card">
            <img src="/assets/images/team-member-3.jpg" alt="Mike Chen, Project Manager" width="340" height="400" class="teams__card-image" loading="lazy" />
            <h3 class="teams__card-name">Mike Chen</h3>
            <p class="teams__card-role">Project Manager</p>
          </div>
          <div class="teams__card">
            <img src="/assets/images/team-member-4.jpg" alt="Emily Davis, Operations" width="340" height="400" class="teams__card-image" loading="lazy" />
            <h3 class="teams__card-name">Emily Davis</h3>
            <p class="teams__card-role">Operations</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== CONTACT SECTION ========== -->
    <section class="contact-section">
      <div class="contact-section__inner container">
        <div class="contact-section__content">
          <span class="section-label">HANDYHUB</span>
          <h2 class="contact-section__heading">Ready to get started?</h2>
          <p class="contact-section__text">
            Get in touch with us today for a free estimate. Our team is ready to help with all your home improvement needs.
          </p>
          <a href="/contact" class="btn">Contact us</a>
        </div>
        <div class="contact-section__image-wrapper">
          <img
            src="/assets/images/about-contact.jpg"
            alt="Professional handyman ready to assist"
            width="552"
            height="400"
            class="contact-section__image"
            loading="lazy"
          />
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggles = document.querySelectorAll('.why-choose__card-toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const card = toggle.closest('.why-choose__card');
        const body = card.querySelector('.why-choose__card-body');
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isOpen));
        if (isOpen) {
          body.setAttribute('hidden', '');
          card.classList.remove('why-choose__card--open');
          toggle.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/><line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2"/></svg>';
        } else {
          body.removeAttribute('hidden');
          card.classList.add('why-choose__card--open');
          toggle.innerHTML = '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2"/></svg>';
        }
      });
    });
  });
</script>

<style>
  /* ========== ABOUT HERO ========== */
  .about-hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    position: relative;
    overflow: hidden;
    min-height: 54em;
  }

  .about-hero__lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    justify-content: space-evenly;
    max-width: var(--size-container);
    margin-inline: auto;
    padding-inline: var(--container-padding);
  }

  .about-hero__lines span {
    width: 1px;
    height: 100%;
    background-color: var(--color-border-dark);
  }

  .about-hero__image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 40.75em;
    height: 100%;
  }

  .about-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    min-height: 54em;
    padding-block: 5em;
  }

  .about-hero__content {
    width: 34.5em;
  }

  .about-hero__eyebrow {
    display: block;
    color: var(--color-text-white-muted);
    margin-bottom: 1.5em;
  }

  .about-hero__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.92px;
    color: var(--color-text-white);
    margin-bottom: 0.4em;
  }

  .about-hero__text {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-white-muted);
    margin-bottom: 2em;
  }

  .about-hero__stats {
    display: flex;
    gap: 3em;
    margin-top: 3em;
    padding-top: 2em;
    border-top: 1px solid var(--color-border-dark);
  }

  .about-hero__stat {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }

  .about-hero__stat-number {
    font-family: var(--font-heading);
    font-size: 2em;
    font-weight: 400;
    line-height: 1.25;
    color: var(--color-text-white);
  }

  .about-hero__stat-label {
    font-family: var(--font-body);
    font-size: 0.75em;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 1.44px;
    text-transform: uppercase;
    color: var(--color-text-white-muted);
  }

  /* ========== WHY CHOOSE US ========== */
  .why-choose {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 7.5em;
  }

  .why-choose__inner {
    padding-inline: var(--container-padding);
  }

  .why-choose__header {
    margin-bottom: 3.75em;
  }

  .why-choose__header .section-label {
    display: block;
    color: var(--color-text-secondary);
    margin-bottom: 1em;
  }

  .why-choose__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.92px;
    color: var(--color-text-primary);
    margin-bottom: 0.267em;
  }

  .why-choose__subtext {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-secondary);
    max-width: 34.5em;
  }

  .why-choose__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25em;
  }

  .why-choose__card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2em;
    background-color: transparent;
  }

  .why-choose__card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .why-choose__card-icon-title {
    display: flex;
    align-items: center;
    gap: 0.75em;
  }

  .why-choose__card-icon {
    width: 1.5em;
    height: 1.5em;
    flex-shrink: 0;
  }

  .why-choose__card-title {
    font-family: var(--font-heading);
    font-size: 1.25em;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-primary);
  }

  .why-choose__card-toggle {
    width: 2.5em;
    height: 2.5em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    cursor: pointer;
    color: var(--color-text-primary);
    flex-shrink: 0;
  }

  .why-choose__card-body {
    margin-top: 1em;
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-secondary);
  }

  /* ========== OUR STORY ========== */
  .our-story {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 7.5em;
  }

  .our-story__inner {
    display: flex;
    gap: 3.75em;
    align-items: flex-start;
    padding-inline: var(--container-padding);
  }

  .our-story__image-col {
    flex: 1;
    min-width: 0;
  }

  .our-story__image {
    width: 100%;
    height: 39.8125em;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .our-story__content {
    flex: 1;
    min-width: 0;
  }

  .our-story__content .section-label {
    display: block;
    color: var(--color-text-secondary);
    margin-bottom: 1em;
  }

  .our-story__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.92px;
    color: var(--color-text-primary);
    margin-bottom: 0.267em;
  }

  .our-story__text {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-secondary);
    margin-bottom: 2.5em;
  }

  .our-story__items {
    display: flex;
    flex-direction: column;
    gap: 1.5em;
  }

  .our-story__item {
    display: flex;
    gap: 1em;
    align-items: flex-start;
  }

  .our-story__item-icon {
    width: 1.5em;
    height: 1.5em;
    flex-shrink: 0;
    margin-top: 0.125em;
  }

  .our-story__item-title {
    font-family: var(--font-heading);
    font-size: 1.25em;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-primary);
    margin-bottom: 0.25em;
  }

  .our-story__item-text {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-secondary);
  }

  /* ========== TEAMS ========== */
  .teams {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 7.5em;
  }

  .teams__inner {
    padding-inline: var(--container-padding);
  }

  .teams__header {
    text-align: center;
    margin-bottom: 3.75em;
  }

  .teams__header .section-label {
    display: block;
    color: var(--color-text-secondary);
    margin-bottom: 1em;
  }

  .teams__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.92px;
    color: var(--color-text-primary);
    margin-bottom: 0.267em;
  }

  .teams__subtext {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-secondary);
    max-width: 34.5em;
    margin-inline: auto;
  }

  .teams__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25em;
  }

  .teams__card {
    text-align: center;
  }

  .teams__card-image {
    width: 100%;
    height: 25em;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin-bottom: 1em;
  }

  .teams__card-name {
    font-family: var(--font-heading);
    font-size: 1.25em;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-primary);
  }

  .teams__card-role {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-secondary);
  }

  /* ========== CONTACT SECTION ========== */
  .contact-section {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 7.5em;
  }

  .contact-section__inner {
    display: flex;
    align-items: center;
    gap: 3.75em;
    padding-inline: var(--container-padding);
  }

  .contact-section__content {
    flex: 1;
    min-width: 0;
  }

  .contact-section__content .section-label {
    display: block;
    color: var(--color-text-white-muted);
    margin-bottom: 1em;
  }

  .contact-section__heading {
    font-family: var(--font-heading);
    font-size: 3.75em;
    font-weight: 400;
    line-height: 1.133;
    letter-spacing: -1.92px;
    color: var(--color-text-white);
    margin-bottom: 0.267em;
  }

  .contact-section__text {
    font-size: 0.875em;
    line-height: 1.429;
    color: var(--color-text-white-muted);
    margin-bottom: 2em;
  }

  .contact-section__image-wrapper {
    flex: 1;
    min-width: 0;
  }

  .contact-section__image {
    width: 100%;
    height: 25em;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  /* ========== RESPONSIVE ========== */

  /* Tablet */
  @media (max-width: 991px) {
    .about-hero {
      min-height: auto;
    }

    .about-hero__image-wrapper {
      position: relative;
      width: 100%;
      height: 25em;
    }

    .about-hero__inner {
      justify-content: center;
      min-height: auto;
      padding-block: 3em;
    }

    .about-hero__content {
      width: 100%;
    }

    .why-choose__grid {
      grid-template-columns: 1fr;
    }

    .our-story__inner {
      flex-direction: column;
    }

    .our-story__image {
      height: 25em;
    }

    .teams__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .contact-section__inner {
      flex-direction: column;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .about-hero__image-wrapper {
      height: 20em;
    }

    .about-hero__heading {
      font-size: 2.5em;
    }

    .about-hero__stats {
      flex-wrap: wrap;
      gap: 2em;
    }

    .why-choose__heading,
    .our-story__heading,
    .teams__heading,
    .contact-section__heading {
      font-size: 2.5em;
    }

    .our-story__image {
      height: 18em;
    }

    .teams__grid {
      grid-template-columns: 1fr;
    }

    .contact-section__image {
      height: 18em;
    }
  }

  /* Mobile portrait */
  @media (max-width: 479px) {
    .about-hero__heading {
      font-size: 2em;
    }

    .about-hero__stats {
      flex-direction: column;
      gap: 1.5em;
    }

    .why-choose__heading,
    .our-story__heading,
    .teams__heading,
    .contact-section__heading {
      font-size: 2em;
    }
  }
</style>
