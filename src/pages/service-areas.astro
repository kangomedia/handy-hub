---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Service Areas — Elite Property Innovations | Westminster, Denver Metro"
  description="Elite Property Innovations proudly serves Westminster, Arvada, Broomfield, Erie, Lafayette & Denver. Quality home remodeling, handyman services & repairs. Call (720) 299-1238."
>
  <Navbar variant="dark" />
  <main id="main-content">

    <!-- Hero -->
    <section class="sa-hero">
      <div class="sa-hero__gradient" aria-hidden="true"></div>
      <div class="sa-hero__grid-overlay" aria-hidden="true"></div>
      <div class="sa-hero__content container">
        <div class="sa-hero__text">
          <span class="section-label sa-hero__eyebrow">Service Areas</span>
          <h1 class="sa-hero__heading">Proudly Serving the Denver&nbsp;Metro&nbsp;Area</h1>
          <p class="sa-hero__subtext">From Westminster to Denver, Elite Property Innovations delivers expert home remodeling, handyman services, and property improvements to homeowners across Colorado's Front Range.</p>
          <div class="sa-hero__ctas">
            <a href="/contact" class="btn btn--accent">Get a Free Estimate</a>
            <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
          </div>
        </div>
        <div class="sa-hero__stats">
          <div class="sa-hero__stat">
            <span class="sa-hero__stat-number">6</span>
            <span class="sa-hero__stat-label">CITIES SERVED</span>
          </div>
          <div class="sa-hero__stat">
            <span class="sa-hero__stat-number">25+</span>
            <span class="sa-hero__stat-label">YEARS EXPERIENCE</span>
          </div>
          <div class="sa-hero__stat">
            <span class="sa-hero__stat-number">5.0★</span>
            <span class="sa-hero__stat-label">GOOGLE RATING</span>
          </div>
          <div class="sa-hero__stat">
            <span class="sa-hero__stat-number">1,000+</span>
            <span class="sa-hero__stat-label">PROJECTS COMPLETED</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Service Areas Grid -->
    <section class="sa-grid-section">
      <div class="sa-grid-section__inner container">
        <span class="section-label">Where We Work</span>
        <h2 class="sa-grid-section__heading">Our Service Areas</h2>
        <p class="sa-grid-section__subtext">We bring the same level of expert craftsmanship, transparent pricing, and dedicated customer service to every community we serve throughout the Denver metro area.</p>

        <div class="sa-cards">
          <a href="/service-areas/westminster" class="sa-card">
            <div class="sa-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="sa-card__title">Westminster, CO</h3>
            <p class="sa-card__desc">Our home base. We've been transforming Westminster homes for over 25 years — from kitchen remodels to complete property renovations.</p>
            <span class="sa-card__link">View Westminster Services →</span>
          </a>

          <a href="/service-areas/arvada" class="sa-card">
            <div class="sa-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="sa-card__title">Arvada, CO</h3>
            <p class="sa-card__desc">Arvada homeowners trust us for reliable remodeling and repair services — from historic Olde Town properties to modern subdivisions.</p>
            <span class="sa-card__link">View Arvada Services →</span>
          </a>

          <a href="/service-areas/broomfield" class="sa-card">
            <div class="sa-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="sa-card__title">Broomfield, CO</h3>
            <p class="sa-card__desc">Serving Broomfield's growing community with expert craftsmanship. From quick handyman fixes to full-scale remodeling projects.</p>
            <span class="sa-card__link">View Broomfield Services →</span>
          </a>

          <a href="/service-areas/erie" class="sa-card">
            <div class="sa-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="sa-card__title">Erie, CO</h3>
            <p class="sa-card__desc">Erie's fast-growing neighborhoods deserve premium home improvement. We deliver quality upgrades that increase property value.</p>
            <span class="sa-card__link">View Erie Services →</span>
          </a>

          <a href="/service-areas/lafayette" class="sa-card">
            <div class="sa-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="sa-card__title">Lafayette, CO</h3>
            <p class="sa-card__desc">From charming older homes to newer developments, Lafayette residents rely on us for detailed, dependable property improvements.</p>
            <span class="sa-card__link">View Lafayette Services →</span>
          </a>

          <a href="/service-areas/denver" class="sa-card">
            <div class="sa-card__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3 class="sa-card__title">Denver, CO</h3>
            <p class="sa-card__desc">The Mile High City's most trusted home improvement partner. We handle everything from downtown condos to suburban family homes.</p>
            <span class="sa-card__link">View Denver Services →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Services Available -->
    <section class="sa-services">
      <div class="sa-services__inner container">
        <span class="section-label">Available in Every Service Area</span>
        <h2 class="sa-services__heading">Our Full Range of Services</h2>
        <p class="sa-services__subtext">No matter where you are in the Denver metro area, you have access to our complete list of professional home improvement services.</p>

        <div class="sa-services__grid">
          <a href="/services/kitchen-remodeling" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/><path d="M3 9V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4"/></svg>
            <span>Kitchen Remodeling</span>
          </a>
          <a href="/services/bathroom-remodeling" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12h16a1 1 0 0 1 1 1v3a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4v-3a1 1 0 0 1 1-1z"/><path d="M6 12V5a2 2 0 0 1 2-2h1"/></svg>
            <span>Bathroom Remodeling</span>
          </a>
          <a href="/services/painting" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 3H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/><path d="M12 11v6"/><path d="M8 17h8"/></svg>
            <span>Interior & Exterior Painting</span>
          </a>
          <a href="/services/handyman" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            <span>Handyman Services</span>
          </a>
          <a href="/services/drywall" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></svg>
            <span>Drywall Services</span>
          </a>
          <a href="/services/carpentry" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20V8l7-5 7 5v12"/><path d="M9 20v-6h6v6"/></svg>
            <span>Carpentry</span>
          </a>
          <a href="/services/deck-construction" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 6v12"/><path d="M2 12h20"/></svg>
            <span>Deck Construction</span>
          </a>
          <a href="/services/fencing" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="2" x2="4" y2="22"/><line x1="12" y1="2" x2="12" y2="22"/><line x1="20" y1="2" x2="20" y2="22"/><line x1="2" y1="8" x2="22" y2="8"/><line x1="2" y1="16" x2="22" y2="16"/></svg>
            <span>Fence Installation</span>
          </a>
          <a href="/services/windows-doors" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="12" y1="3" x2="12" y2="21"/><line x1="3" y1="12" x2="12" y2="12"/></svg>
            <span>Window & Door Replacement</span>
          </a>
          <a href="/services/roofing" class="sa-service-item">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-4h6v4"/></svg>
            <span>Roofing Services</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="sa-cta-banner">
      <div class="sa-cta-banner__inner container">
        <h2 class="sa-cta-banner__heading">Ready to Start Your Project?</h2>
        <p class="sa-cta-banner__text">No matter where you are in the Denver metro area, we'll come to you. Get a detailed, no-obligation estimate for any home improvement project.</p>
        <div class="sa-cta-banner__actions">
          <a href="/contact" class="btn btn--accent">Get Your Free Estimate</a>
          <a href="tel:7202991238" class="btn btn--outline">(720) 299-1238</a>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>

<style>
  /* Hero */
  .sa-hero {
    width: 100%;
    background-color: var(--color-bg-dark);
    background-image: url('/assets/images/hero-home.jpg');
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    padding: 10em 0 6em;
  }

  .sa-hero__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10, 15, 20, 0.8) 0%, rgba(10, 15, 20, 0.92) 100%),
                radial-gradient(ellipse at 30% 20%, rgba(0, 200, 232, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(168, 224, 0, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .sa-hero__grid-overlay {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(135deg, rgba(255,255,255,0.02) 0px, rgba(255,255,255,0.02) 1px, transparent 1px, transparent 60px);
    pointer-events: none;
  }

  .sa-hero__content { position: relative; z-index: 2; }
  .sa-hero__text { display: flex; flex-direction: column; align-items: flex-start; max-width: 36em; }
  .sa-hero__eyebrow { margin-bottom: 1.5em; }

  .sa-hero__heading {
    font-family: var(--font-heading);
    font-size: 3.5em;
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-text-white);
    margin-bottom: 0.4em;
  }

  .sa-hero__subtext {
    font-size: 1.0625em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 2em;
  }

  .sa-hero__ctas { display: flex; gap: 1em; flex-wrap: wrap; }

  .sa-hero__stats {
    display: flex;
    gap: 3em;
    margin-top: 3em;
    padding-top: 2em;
    border-top: 1px solid var(--color-border);
  }

  .sa-hero__stat { display: flex; flex-direction: column; gap: 0.25em; }

  .sa-hero__stat-number {
    font-family: var(--font-heading);
    font-size: 2em;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text-white);
  }

  .sa-hero__stat-label {
    font-size: 0.6875em;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  /* Service Areas Grid */
  .sa-grid-section {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 6.25em;
  }

  .sa-grid-section__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .sa-grid-section__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-top: 0.75em;
    margin-bottom: 0.5em;
  }

  .sa-grid-section__subtext {
    font-size: 1em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 40em;
    margin-bottom: 3em;
  }

  .sa-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25em;
    width: 100%;
    max-width: 64em;
  }

  .sa-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    padding: 2em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    cursor: pointer;
  }

  .sa-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .sa-card__icon-wrap {
    width: 3em;
    height: 3em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 200, 232, 0.08);
    border-radius: var(--radius-md);
    margin-bottom: 1.25em;
    color: var(--color-primary);
  }

  .sa-card__title {
    font-family: var(--font-heading);
    font-size: 1.25em;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .sa-card__desc {
    font-size: 0.875em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: 1.25em;
    flex: 1;
  }

  .sa-card__link {
    font-family: var(--font-heading);
    font-size: 0.8125em;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.5px;
    transition: opacity var(--transition-base);
  }

  .sa-card:hover .sa-card__link { opacity: 0.8; }

  /* Services Available Section */
  .sa-services {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 6.25em;
    border-top: 1px solid var(--color-border);
  }

  .sa-services__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .sa-services__heading {
    font-family: var(--font-heading);
    font-size: 2.75em;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text-white);
    margin-top: 0.75em;
    margin-bottom: 0.5em;
  }

  .sa-services__subtext {
    font-size: 1em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 40em;
    margin-bottom: 3em;
  }

  .sa-services__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1em;
    width: 100%;
    max-width: 64em;
  }

  .sa-service-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75em;
    padding: 1.5em 1em;
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    color: var(--color-primary);
    text-align: center;
  }

  .sa-service-item span {
    font-family: var(--font-body);
    font-size: 0.8125em;
    font-weight: 600;
    color: var(--color-text-white);
    line-height: 1.3;
  }

  .sa-service-item:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-card-hover);
  }

  /* CTA Banner */
  .sa-cta-banner {
    width: 100%;
    background-color: var(--color-bg-dark);
    background-image: url('/assets/images/hero-cta.jpg');
    background-size: cover;
    background-position: center;
    border-top: 1px solid var(--color-border);
    padding-block: 5em;
    position: relative;
  }

  .sa-cta-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10, 15, 20, 0.88) 0%, rgba(10, 15, 20, 0.94) 100%);
    pointer-events: none;
  }

  .sa-cta-banner__inner { text-align: center; position: relative; z-index: 1; }

  .sa-cta-banner__heading {
    font-family: var(--font-heading);
    font-size: 2.5em;
    font-weight: 800;
    color: var(--color-text-white);
    margin-bottom: 0.5em;
  }

  .sa-cta-banner__text {
    font-size: 1.0625em;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 36em;
    margin-inline: auto;
    margin-bottom: 2em;
  }

  .sa-cta-banner__actions { display: flex; gap: 1em; justify-content: center; flex-wrap: wrap; }

  /* Responsive */
  @media (max-width: 991px) {
    .sa-hero__heading { font-size: 2.75em; }
    .sa-hero__stats { flex-wrap: wrap; gap: 2em; }
    .sa-cards { grid-template-columns: repeat(2, 1fr); }
    .sa-services__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 767px) {
    .sa-hero { padding: 8em 0 4em; }
    .sa-hero__heading { font-size: 2.25em; }
    .sa-hero__stats { gap: 1.5em; }
    .sa-hero__stat-number { font-size: 1.75em; }
    .sa-cards { grid-template-columns: 1fr; }
    .sa-services__grid { grid-template-columns: repeat(2, 1fr); }
    .sa-cta-banner__heading { font-size: 2em; }
  }

  @media (max-width: 479px) {
    .sa-hero__heading { font-size: 1.875em; }
    .sa-hero__stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5em; }
    .sa-hero__stat-number { font-size: 1.5em; }
    .sa-hero__ctas, .sa-cta-banner__actions { flex-direction: column; width: 100%; }
    .sa-hero__ctas .btn, .sa-cta-banner__actions .btn { width: 100%; }
    .sa-services__grid { grid-template-columns: 1fr; }
    .sa-cta-banner__heading { font-size: 1.75em; }
  }
</style>
